# Python venv for local extraction work (Python 3.14 with pypdfium2 + Pillow)
.venv-extract/

# Smoke-test render output (regeneratable from scripts/llm-extract/rasterize_smoke_test.py)
/tmp/render-smoke-test/

# Bake-off intermediate output (regenerated by scripts/llm-extract/driver.py)
/data/bake-off-output/

# Phase B NER derived artifacts (regenerable from content on demand)
data/synthesis/ner-input.jsonl
data/synthesis/ner-mentions.jsonl
data/synthesis/ner-rejected.txt
data/synthesis/ner-smoke-input.jsonl

# LLM extraction request packages (regenerated per dispatch in /tmp)
/tmp/llm-extract-requests/
response.json
