---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import { BCP47, OG_LOCALE, type LangCode } from "~/lib/i18n";

interface HreflangAlternate {
  hreflang: string;
  href: string;
}

interface Props {
  title?: string;
  description?: string;
  /** BCP 47-prefixed code is fine; this is the `<html lang>` value */
  lang?: LangCode;
  noindex?: boolean;
  /** When this page is part of a translation set, pass the bidirectional
   *  hreflang alternates (computed via hreflangAlternates() in lib/i18n.ts).
   *  Must include a self-referential entry and an x-default. */
  hreflang?: HreflangAlternate[];
  /** Override the canonical URL (defaults to the current request URL). */
  canonical?: string;
}

const {
  title = "Indian Liberals — An Online Archive of Indian Liberal Works",
  description = "A digital archive of the Indian liberal tradition. Primary works, thinker profiles, organisations, opinions, and curated excerpts from the figures who built the case for liberty in modern India.",
  lang = "en",
  noindex = false,
  hreflang = [],
  canonical,
} = Astro.props;

const resolvedCanonical =
  canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const ogLocale = OG_LOCALE[lang as LangCode] ?? OG_LOCALE.en;
const ogLocaleAlternates = hreflang
  .filter((h) => h.hreflang !== "x-default" && h.hreflang !== BCP47[lang as LangCode])
  .map((h) => h.hreflang.replace("-", "_"));
const htmlLang = BCP47[lang as LangCode] ?? "en-IN";
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Canonical: self-referential per Google guidance for multilingual.
         Each language version is canonical to itself, not to a "master". -->
    <link rel="canonical" href={resolvedCanonical} />

    {noindex && <meta name="robots" content="noindex,follow" />}

    <!-- hreflang alternates — bidirectional translation graph.
         Every page in a translation set lists every other language version,
         a self-referential entry, and an x-default. -->
    {hreflang.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <link rel="icon" type="image/png" sizes="32x32" href="/brand/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/brand/favicon-192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/brand/favicon-180.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/brand/favicon-512.png" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={new URL("/brand/logo.png", Astro.site)} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((loc) => (
      <meta property="og:locale:alternate" content={loc} />
    ))}

    <meta name="generator" content={Astro.generator} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-(--color-bg) focus:text-(--color-forest-700) focus:px-3 focus:py-2 focus:rounded focus:border focus:border-(--color-border)">
      Skip to content
    </a>
    <Header />
    <!-- data-pagefind-body marks this region as the search-indexable content
         on every page. Per-page <article> elements add data-pagefind-filter
         and data-pagefind-meta to scope facets without re-defining the body. -->
    <main id="main" class="min-h-[calc(100vh-12rem)]" data-pagefind-body>
      <slot />
    </main>
    <Footer />
  </body>
</html>
