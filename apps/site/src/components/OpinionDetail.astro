---
// OpinionDetail.astro — shared full-UI component for opinion entries.
//
// INVENTORY — which template each section came from:
//   FROM English only (previously missing in i18n route):
//     - authorEntry resolution via getEntry() — i18n only used the raw
//       author_name string fallback; now both routes resolve the contributor
//       reference when present.
//     - subjectEntry resolution via getEntry() — i18n lacked the "About
//       <thinker>" link in the byline; English already had it.
//     - ContributorCard "Written by" card (shown when authorEntry resolves);
//       i18n template had no card at all. Per plan: contributors are
//       language-neutral, so the card is appropriate on i18n opinion pages.
//     - PeopleInPiece component (author/subject/mention slugs).
//     - RelatedSection component.
//   FROM i18n only (previously extra, now DROPPED per plan):
//     - lang={o.data.language} on <h1> and on the prose-container div —
//       BaseLayout already sets <html lang> to the page language, so these
//       per-element attributes were redundant. Dropped here.
//   BOTH routes retained (kept as-is):
//     - "Opinion" eyebrow, h1 title.
//     - pubDate formatted with en-IN locale.
//     - Conditional author byline: authorEntry link → author_name fallback →
//       nothing (Editorial Team strings suppressed).
//     - key_concepts chips.
//     - prose-container block with opinion-specific styling.
//     - data-pagefind-filter="type:opinion,lang:X" on <article>.
//     - noindex={shouldNoindex(translation_status)}.
//     - hreflangAlternates / lang / hreflang passed to BaseLayout.
//   LANG-CONDITIONAL:
//     - key_concepts chip link prefix differs between English (/opinions/) and
//       i18n (/<lang>/opinions/). The component computes `opinionsListBase`
//       via pathForCollection() from ~/lib/i18n — the shared helper that
//       musings/interviews should also use (Chunks 5/6).
//   No description is passed to BaseLayout from either original template;
//   that is preserved here (rely on BaseLayout's own default).

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { hreflangAlternates, shouldNoindex, pathForCollection } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";
import PeopleInPiece from "~/components/PeopleInPiece.astro";
import ContributorCard from "~/components/ContributorCard.astro";

interface Props {
  entry: CollectionEntry<"opinions">;
}

const { entry } = Astro.props;
// Alias for ergonomics — existing template logic uses `o`.
const o = entry;
const { Content } = await render(o);

const hreflang = hreflangAlternates(
  "opinions",
  o.id,
  o.data.language,
  o.data.translations,
  Astro.site!.origin,
);

// Resolve byline contributor (if any) and subject (profile pieces).
const authorEntry = o.data.author ? await getEntry(o.data.author) : null;
const subjectEntry = o.data.subject ? await getEntry(o.data.subject) : null;

const authorSlugs = authorEntry ? [authorEntry.id] : [];
const subjectSlugs = subjectEntry ? [subjectEntry.id] : [];
const mentionSlugs = (o.data.thinker_mentions ?? [])
  .map((mn: any) => (typeof mn.thinker === "string" ? mn.thinker : mn.thinker?.id))
  .filter(Boolean);

// LANG-CONDITIONAL: chip links must point at the correct collection index.
// Computed via the shared pathForCollection() helper (see ~/lib/i18n) so the
// same pattern works for musings/interviews without re-implementing the logic.
const opinionsListBase = pathForCollection("opinions", o.data.language);
---

<BaseLayout
  title={`${o.data.title} — Indian Liberals`}
  lang={o.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(o.data.translation_status)}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16" data-pagefind-filter={`type:opinion,lang:${o.data.language}`}>
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        Opinion
      </p>
      <h1 class="text-(--color-fg) leading-tight">{o.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(o.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}
        {authorEntry ? (
          <>
            {" · By "}
            <a href={`/contributors/${authorEntry.id}/`} class="text-(--color-fg) font-semibold no-underline hover:text-(--color-forest-700)">
              {authorEntry.data.name.canonical}
            </a>
          </>
        ) : o.data.author_name && o.data.author_name !== "Editorial Team" && o.data.author_name !== "CCS Editorial Team" ? (
          <span> · {o.data.author_name}</span>
        ) : null}
        {subjectEntry && (
          <>
            {" · About "}
            <a href={`/thinkers/${subjectEntry.id}/`} class="text-(--color-fg) font-semibold no-underline hover:text-(--color-forest-700)">
              {subjectEntry.data.name.canonical}
            </a>
          </>
        )}
      </p>
      {o.data.key_concepts && o.data.key_concepts.length > 0 && (
        <ul class="flex flex-wrap gap-1.5 mt-3 not-prose">
          {o.data.key_concepts.map((kc) => (
            <li>
              <a
                href={`${opinionsListBase}?key_concept=${encodeURIComponent(kc)}`}
                class="inline-block px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg-muted) hover:border-(--color-fg) hover:text-(--color-fg) transition-colors font-(family-name:--font-ui)"
              >
                {kc.replace(/-/g, " ")}
              </a>
            </li>
          ))}
        </ul>
      )}
    </header>
    <div class="prose-container text-(--color-fg) leading-relaxed text-[1.0625rem] [&_p]:my-5 [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_a]:text-(--color-forest-700) [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted) [&_blockquote]:my-5">
      <Content />
    </div>

    {authorEntry && (
      <ContributorCard contributor={authorEntry} variant="inline" />
    )}

    <PeopleInPiece authorSlugs={authorSlugs} subjectSlugs={subjectSlugs} mentionSlugs={mentionSlugs} />

    <RelatedSection collection="opinions" slug={o.id} viewerLang={o.data.language} />
  </article>
</BaseLayout>
