---
// MusingDetail.astro — shared full-UI component for musing entries.
//
// INVENTORY — which template each section came from:
//   FROM English only (previously missing in i18n route):
//     - authorEntry resolution via getEntry() — i18n route had no byline at all.
//     - "· By <thinker>" byline link pointing to /thinkers/<id>/ (musings link
//       to thinkers, not contributors — author is a thinker reference).
//     - PeopleInPiece component (authorSlugs + mentionSlugs; musings have no
//       subjectSlugs).
//     - RelatedSection component.
//     - "· excerpt" suffix in eyebrow — i18n template showed only "Musing".
//       Per plan: English is source of truth; shared component renders
//       "Musing · excerpt". When i18n musing MDs land, they get the same
//       eyebrow.
//   FROM i18n only (previously extra, now DROPPED per plan):
//     - lang={m.data.language} on <h1> — BaseLayout already sets <html lang>;
//       per-element attribute was redundant. Dropped here.
//     - lang={m.data.language} on prose-container div — same reason. Dropped.
//   BOTH routes retained (kept as-is):
//     - pubDate formatted with en-IN locale.
//     - key_concepts chips.
//     - prose-container block with musing-specific styling.
//     - data-pagefind-filter="type:musing,lang:X" on <article>.
//     - noindex={shouldNoindex(translation_status)}.
//     - hreflangAlternates / lang / hreflang passed to BaseLayout.
//   LANG-CONDITIONAL:
//     - key_concepts chip link prefix computed via pathForCollection("musings",
//       language) — same shared helper used by OpinionDetail (Chunk 4).
//   No description is passed to BaseLayout (preserved from both originals;
//   rely on BaseLayout's own default).

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getEntry, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { hreflangAlternates, shouldNoindex, pathForCollection } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";
import PeopleInPiece from "~/components/PeopleInPiece.astro";

interface Props {
  entry: CollectionEntry<"musings">;
}

const { entry } = Astro.props;
// Alias for ergonomics — existing template logic uses `m`.
const m = entry;
const { Content } = await render(m);

const hreflang = hreflangAlternates(
  "musings",
  m.id,
  m.data.language,
  m.data.translations,
  Astro.site!.origin,
);

// Resolve byline thinker so we can render a link to their bio.
// Musings link to /thinkers/, not /contributors/.
const authorEntry = m.data.author ? await getEntry(m.data.author) : null;

// Slug arrays for the "People in this piece" chip list.
// Musings have no subjectSlugs.
const authorSlugs = authorEntry ? [authorEntry.id] : [];
const mentionSlugs = (m.data.thinker_mentions ?? [])
  .map((mn: any) => (typeof mn.thinker === "string" ? mn.thinker : mn.thinker?.id))
  .filter(Boolean);

// LANG-CONDITIONAL: chip links must point at the correct collection index.
// Computed via the shared pathForCollection() helper (see ~/lib/i18n).
const musingsListBase = pathForCollection("musings", m.data.language);
---

<BaseLayout
  title={`${m.data.title} — Indian Liberals`}
  lang={m.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(m.data.translation_status)}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16" data-pagefind-filter={`type:musing,lang:${m.data.language}`}>
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        Musing · excerpt
      </p>
      <h1 class="text-(--color-fg) leading-tight">{m.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(m.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}
        {authorEntry && (
          <>
            {" · By "}
            <a href={`/thinkers/${authorEntry.id}/`} class="text-(--color-fg) font-semibold no-underline hover:text-(--color-forest-700)">
              {authorEntry.data.name.canonical}
            </a>
          </>
        )}
      </p>
      {m.data.key_concepts && m.data.key_concepts.length > 0 && (
        <ul class="flex flex-wrap gap-1.5 mt-3 not-prose">
          {m.data.key_concepts.map((kc) => (
            <li>
              <a
                href={`${musingsListBase}?key_concept=${encodeURIComponent(kc)}`}
                class="inline-block px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg-muted) hover:border-(--color-fg) hover:text-(--color-fg) transition-colors font-(family-name:--font-ui)"
              >
                {kc.replace(/-/g, " ")}
              </a>
            </li>
          ))}
        </ul>
      )}
    </header>
    <div class="prose-container text-(--color-fg) leading-relaxed text-[1.0625rem] [&_p]:my-5 [&_a]:text-(--color-forest-700) [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted) [&_blockquote]:my-5">
      <Content />
    </div>

    <PeopleInPiece authorSlugs={authorSlugs} mentionSlugs={mentionSlugs} />

    <RelatedSection collection="musings" slug={m.id} viewerLang={m.data.language} />
  </article>
</BaseLayout>
