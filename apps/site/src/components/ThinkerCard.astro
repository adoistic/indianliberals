---
import { Image } from "astro:assets";

interface Props {
  slug: string;
  name: string;
  dates?: string;
  portrait?: string;
  variant?: "caricature" | "photo" | "ring";
}

const { slug, name, dates, portrait, variant = "caricature" } = Astro.props;

const treatmentLabel = {
  caricature: "Sketch",
  photo: "Photograph",
  ring: "Portrait",
}[variant];
---

<a
  href={`/thinkers/${slug}/`}
  class="group block no-underline"
  aria-label={`Thinker profile: ${name}${dates ? ` (${dates})` : ""}`}
>
  <div class="aspect-[3/4] bg-(--color-bg-muted) border border-(--color-border) overflow-hidden rounded-sm flex items-end justify-center transition-shadow group-hover:shadow-md">
    {portrait ? (
      <img
        src={portrait}
        alt=""
        width="240"
        height="320"
        loading="lazy"
        class="w-full h-full object-contain object-bottom group-hover:scale-[1.02] transition-transform duration-300"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-(--color-fg-muted) font-(family-name:--font-display)">
        <span class="text-4xl">?</span>
      </div>
    )}
  </div>
  <div class="mt-3 px-1">
    <h3 class="font-(family-name:--font-display) font-semibold text-(--color-fg) leading-tight group-hover:text-(--color-saffron-700) transition-colors">{name}</h3>
    {dates && <p class="text-sm text-(--color-fg-muted) mt-0.5 font-(family-name:--font-ui)">{dates}</p>}
    <p class="text-[10px] uppercase tracking-widest text-(--color-fg-muted) mt-2 font-(family-name:--font-ui)">{treatmentLabel}</p>
  </div>
</a>
