---
// OrganisationDetail.astro — shared full-UI component for organisation entries.
//
// INVENTORY — which template each section came from:
//   FROM English only (previously missing in i18n route):
//     - full name italic paragraph (name.full when different from canonical)
//     - Also known as line (name.also_known_as)
//     - Works published / issued section (iterates all primary-works, filters by
//       publisher_id or issuer_id, language-aware link via workHref helper, caps at 30)
//     - Affiliated thinkers section (filters thinkers by affiliations.includes(o.id))
//     - Ideology aside (o.data.ideology tags)
//     - RelatedSection component
//     - datesStr helper (Founded YEAR / YEAR–YEAR) — the i18n template used the
//       simpler "founded_year ?? '?'–dissolved_year ?? ''" rendering, which is
//       replaced here by the English template's richer helper
//     - description meta string (English-language; see note below)
//   FROM i18n only (lang= attrs on h1 and prose-container div) — DROPPED per plan:
//     BaseLayout sets the page-level <html lang>; per-element lang= is only
//     needed where the element's language differs from the page language.
//     The i18n template's `lang={o.data.language}` on <h1> and the prose-container
//     div was redundant. Dropped here.
//   BOTH routes (kept as-is):
//     - type chip, h1 canonical name, datesStr paragraph
//     - data-pagefind-filter type:organisation,lang:X on article element
//     - noindex={shouldNoindex(translation_status)}
//     - hreflangAlternates / lang / hreflang passed to BaseLayout
//     - prose-container block with org-specific styling class block
//
// NOTE on description meta string:
//   The string "... organisation profile, affiliated thinkers, and primary works."
//   is English-language. No i18n org MDs currently exist in gu/hi/mr/bn, so this
//   is theoretical. When i18n org MDs land, a language-keyed approach will be
//   needed — for now the string is irrelevant in practice for i18n pages.
//
// NOTE on allThinkers filter:
//   The English template only fetched English thinkers (language === "en"). That
//   filter is preserved here faithfully — no i18n thinker MDs exist, so it's a
//   no-op restriction but matches existing behaviour. When i18n thinker MDs land,
//   this may want revisiting.
//
// NOTE on workHref:
//   The helper is about cross-language links in the "Works published" list, not
//   about the org's own language. Non-English works link to /<lang>/primary-works/
//   <slug>/; English works link to /primary-works/<slug>/.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { hreflangAlternates, shouldNoindex } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";

interface Props {
  entry: CollectionEntry<"organisations">;
}

const { entry } = Astro.props;
// Alias for ergonomics — existing template logic uses `o`.
const o = entry;
const { Content } = await render(o);

const hreflang = hreflangAlternates(
  "organisations",
  o.id,
  o.data.language,
  o.data.translations,
  Astro.site!.origin,
);

const datesStr =
  o.data.founded_year && o.data.dissolved_year
    ? `${o.data.founded_year}–${o.data.dissolved_year}`
    : o.data.founded_year
      ? `Founded ${o.data.founded_year}`
      : "";

// Pull works published by this org + thinkers affiliated with it.
// The language filter is DROPPED here on purpose — the org page is about
// the organisation's full catalogue, not just its English-language works.
// Non-English works link to their /<lang>/primary-works/<slug>/ route
// (the localised detail page); English ones link to /primary-works/<slug>/.
const allWorks = await getCollection(
  "primary-works",
  (w) => !w.data.draft,
);
const publishedHere = allWorks
  .filter((w) => w.data.publication?.publisher_id === o.id || w.data.publication?.issuer_id === o.id)
  .sort((a, b) => (b.data.publication?.year ?? 0) - (a.data.publication?.year ?? 0));

function workHref(w: typeof publishedHere[number]): string {
  return w.data.language && w.data.language !== "en"
    ? `/${w.data.language}/primary-works/${w.id}/`
    : `/primary-works/${w.id}/`;
}

const allThinkers = await getCollection(
  "thinkers",
  (t) => !t.data.draft && t.data.language === "en",
);
const affiliatedThinkers = allThinkers.filter((t) => (t.data.affiliations ?? []).includes(o.id));
---

<BaseLayout
  title={`${o.data.name.canonical} — Indian Liberals`}
  description={`${o.data.name.canonical}${datesStr ? ` (${datesStr})` : ""} — organisation profile, affiliated thinkers, and primary works.`}
  lang={o.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(o.data.translation_status)}
>
  <article
    class="mx-auto max-w-4xl px-6 py-12 md:py-16"
    data-pagefind-filter={`type:organisation,lang:${o.data.language}`}
  >
    <header class="border-b border-(--color-border) pb-10 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-2">
        {o.data.type.replace(/_/g, " ")}
      </p>
      <h1 class="text-(--color-fg) leading-tight">{o.data.name.canonical}</h1>
      {o.data.name.full && o.data.name.full !== o.data.name.canonical && (
        <p class="text-(--color-fg-muted) font-(family-name:--font-display) italic text-lg mt-1">
          {o.data.name.full}
        </p>
      )}
      {datesStr && (
        <p class="text-(--color-fg-muted) font-(family-name:--font-ui) mt-3 text-base">{datesStr}</p>
      )}
      {o.data.name.also_known_as.length > 0 && (
        <p class="text-(--color-fg-muted) text-sm mt-3 font-(family-name:--font-ui)">
          Also known as: {o.data.name.also_known_as.join(", ")}
        </p>
      )}
    </header>

    <div class="prose-container">
      <div class="text-(--color-fg) leading-relaxed [&_p]:my-5 [&_p]:text-[1.0625rem] [&_h2]:mt-10 [&_h2]:mb-4 [&_a]:text-(--color-forest-700) [&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-6">
        <Content />
      </div>
    </div>

    {/* Works published by this organisation */}
    {publishedHere.length > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) font-(family-name:--font-ui) mb-4">
          Works published / issued ({publishedHere.length})
        </h2>
        <ul class="divide-y divide-(--color-border)">
          {publishedHere.slice(0, 30).map((w) => (
            <li class="py-3">
              <a href={workHref(w)} class="block no-underline group">
                <div class="font-(family-name:--font-display) font-semibold text-(--color-fg) group-hover:text-(--color-saffron-700) transition-colors">
                  {w.data.title.main}
                  {w.data.language && w.data.language !== "en" && (
                    <span class="ml-2 px-1.5 py-0.5 text-[10px] uppercase tracking-wider bg-(--color-bg-muted) border border-(--color-border) rounded text-(--color-fg-muted)">
                      {w.data.language}
                    </span>
                  )}
                </div>
                <div class="text-sm text-(--color-fg-muted) font-(family-name:--font-ui)">
                  {w.data.publication?.year} · {w.data.work_type.replace(/_/g, " ")}
                </div>
              </a>
            </li>
          ))}
        </ul>
        {publishedHere.length > 30 && (
          <p class="mt-4 text-sm text-(--color-fg-muted) font-(family-name:--font-ui)">
            …and {publishedHere.length - 30} more
          </p>
        )}
      </section>
    )}

    {/* Affiliated thinkers */}
    {affiliatedThinkers.length > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) font-(family-name:--font-ui) mb-4">
          Affiliated thinkers ({affiliatedThinkers.length})
        </h2>
        <ul class="flex flex-wrap gap-2 font-(family-name:--font-ui)">
          {affiliatedThinkers.map((t) => (
            <li>
              <a
                href={`/thinkers/${t.id}/`}
                class="inline-block px-3 py-1.5 bg-(--color-bg-muted) border border-(--color-border) rounded-full text-sm text-(--color-fg) no-underline hover:border-(--color-fg)"
              >
                {t.data.name.canonical}
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* Ideology tags */}
    {(o.data.ideology ?? []).length > 0 && (
      <aside class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui) text-sm">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-3">Ideological orientation</h2>
        <ul class="flex flex-wrap gap-2">
          {o.data.ideology.map((i) => (
            <li class="px-2.5 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded-full text-(--color-fg)">{i.replace(/_/g, " ")}</li>
          ))}
        </ul>
      </aside>
    )}

    <RelatedSection collection="organisations" slug={o.id} viewerLang={o.data.language} />
  </article>
</BaseLayout>
