---
// ThinkerDetail.astro — shared full-UI component for thinker entries.
//
// INVENTORY — which template each section came from:
//   FROM English only (previously missing in i18n route):
//     - full name italic paragraph (name.full when different from canonical)
//     - Also known as line (name.also_known_as)
//     - bioSourceLabel ("From feature article" when bio_source === "feature_article")
//     - data-pagefind-meta tradition attribute on article element
//     - Themes + Affiliations aside (two-column grid)
//     - Phase B synthesis section: "How <name> is discussed in this archive"
//       (subjectMentions, allMentionRows, topMentions, evidence passages)
//     - "By <name>" section (primary works, excerpts, opinion pieces, ThePrint)
//     - "About <name>" section (interviews, profile pieces with key_passages)
//     - "Mentioned in" section (primary works, opinion pieces, excerpts with evidence)
//     - RelatedSection component
//     - description meta string (language-keyed note below)
//   FROM i18n only (lang= attrs on h1 and prose-div) — DROPPED per plan:
//     BaseLayout sets the page-level <html lang>; per-element lang= is only
//     needed where the element's language differs from the page language.
//     The i18n template's `lang={t.data.language}` on <h1> and the prose div
//     was redundant. Dropped here.
//   BOTH routes (kept as-is):
//     - portrait treatment (caricature → ring_portrait → photo fallback chain)
//     - tradition label chip
//     - h1 canonical name + datesStr
//     - data-pagefind-filter type:thinker,lang:X on article element
//     - noindex={shouldNoindex(translation_status)}
//     - hreflangAlternates / lang / hreflang passed to BaseLayout
//     - prose-container block with [&_p]:my-5 styling (thinker variant, NOT the
//       [&_>_h1]:hidden primary-works variant — thinker bios do not emit an H1)
//
// NOTE on description meta string:
//   The fallback `"Biographical profile of NAME (DATES)."` is English-language.
//   When i18n thinker MDs exist in gu/hi/mr/bn, a language-keyed approach will
//   be needed. For now there are NO i18n thinker entries, so the string is
//   irrelevant in practice for i18n pages.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { hreflangAlternates, shouldNoindex, DEFAULT_LOCALE } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";

interface Props {
  entry: CollectionEntry<"thinkers">;
}

const { entry } = Astro.props;
// Alias for ergonomics — all existing template logic uses `t`.
const t = entry;
const { Content } = await render(t);

// Compute the three-role aggregations at build time. Each Tier-A entry
// has a structured ref pointing to one or more thinkers; we partition
// per the three-role model defined in the cross-link audit spec:
//
//   author  — this thinker WROTE the entry (musings, primary-works,
//             theprint-mirror, opinions with a thinker-author)
//   subject — the entry is ABOUT this thinker (opinions w/ `subject`,
//             interviews w/ `subject`)
//   mention — appears in related_thinkers but is neither author nor
//             subject. Phase B will populate these from in-prose NER.

const [allTheprint, allOpinions, allMusings, allWorks] = await Promise.all([
  getCollection("theprint-mirror", (e) => !e.data.draft),
  getCollection("opinions", (e) => !e.data.draft),
  getCollection("musings", (e) => !e.data.draft),
  getCollection("primary-works", (e) => !e.data.draft && e.data.language === DEFAULT_LOCALE),
]);
// Interviews are now stored as primary-works with work_type='interview'.
// The interviewee (formerly `subject`) is migrated into `authors[0]`.
const allInterviews = allWorks.filter((w) => w.data.work_type === "interview");

function refMatches(ref: { id?: string } | string | undefined, id: string): boolean {
  if (!ref) return false;
  if (typeof ref === "string") return ref === id;
  return ref.id === id;
}

// Phase B — given any entry and the thinker we're rendering, find the
// matching thinker_mentions[] row (or undefined). Used by every section
// that wants to render evidence/key_passages alongside the entry link.
function mentionFor(entry: { data: { thinker_mentions?: Array<any> } }, id: string) {
  return (entry.data.thinker_mentions ?? []).find((m: any) => refMatches(m.thinker, id));
}

// ─── Author role: works/pieces the thinker WROTE ─────────────────────
const worksByThisThinker = allWorks
  .filter((w) =>
    (w.data.authors ?? []).some((a) => refMatches(a, t.id)) ||
    (w.data.contributors ?? []).some((c) => refMatches(c.thinker, t.id)),
  )
  .sort((a, b) => (b.data.publication?.year ?? 0) - (a.data.publication?.year ?? 0));
const musingsByThisThinker = allMusings.filter((m) => refMatches(m.data.author, t.id));
const opinionsByThisThinker = allOpinions.filter((o) => refMatches(o.data.author, t.id));
const theprintByThisThinker = allTheprint.filter((p) =>
  (p.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
);

// ─── Subject role: pieces ABOUT the thinker ──────────────────────────
// For interviews (now primary-works), the interviewee lives in authors[0].
const interviewsAbout = allInterviews.filter((i) =>
  (i.data.authors ?? []).some((a: any) => refMatches(a, t.id))
);
const opinionsAbout = allOpinions.filter((o) => refMatches(o.data.subject, t.id));

// ─── Mention role: appears in related_thinkers but not as author/subject ─
const opinionMentions = allOpinions.filter((o) =>
  !refMatches(o.data.author, t.id) &&
  !refMatches(o.data.subject, t.id) &&
  (o.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
);
const musingMentions = allMusings.filter((m) =>
  !refMatches(m.data.author, t.id) &&
  (m.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
);
// Primary-works where this thinker is mentioned in body prose but not
// an author/contributor. The emitter now projects cross_thinker_mentions
// from the extraction's summary_structured payload into the work's
// related_thinkers[] — so touchstones like Adam Smith, Hayek, Lincoln,
// Marx, Bernard Shaw etc. surface here even though they didn't write
// anything in this corpus.
const workMentions = allWorks
  .filter((w) =>
    !(w.data.authors ?? []).some((a) => refMatches(a, t.id)) &&
    !(w.data.contributors ?? []).some((c) => refMatches(c.thinker, t.id)) &&
    (w.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
  )
  .sort((a, b) => (b.data.publication?.year ?? 0) - (a.data.publication?.year ?? 0));

const authorshipCount =
  worksByThisThinker.length + musingsByThisThinker.length +
  opinionsByThisThinker.length + theprintByThisThinker.length;
const aboutCount = interviewsAbout.length + opinionsAbout.length;
const mentionCount =
  opinionMentions.length + musingMentions.length + workMentions.length;

// Phase B — collect every (entry, mention) pair across the three
// mention-bearing role buckets for the synthesis section. Grouped by
// role so we can render role-bucketed prose like the parent spec calls
// for: "Authored N works including X, Y, Z. Referenced in M others
// including A, B, C."
type MentionRow = { entry: { collection: string; id: string; data: any }; mention: any };

const subjectMentions: MentionRow[] = (opinionsAbout
  .map((e) => {
    const m = mentionFor(e, t.id);
    return m && m.role === 'subject' ? { entry: e as any, mention: m } : null;
  })
  .filter((x) => x !== null) as MentionRow[]);

const allMentionRows: MentionRow[] = ([
  ...workMentions.map((e) => ({ entry: e as any, mention: mentionFor(e, t.id) })),
  ...opinionMentions.map((e) => ({ entry: e as any, mention: mentionFor(e, t.id) })),
  ...musingMentions.map((e) => ({ entry: e as any, mention: mentionFor(e, t.id) })),
].filter((r) => r.mention !== undefined && r.mention.role === 'mention') as MentionRow[]);

const hasPhaseBData = subjectMentions.length > 0 || allMentionRows.length > 0;

// For the inline "...including X, Y, Z" lists — pick up to 3 representative
// works by title, preferring the most-quoted (longest evidence list).
function topByEvidence(rows: MentionRow[], limit = 3): MentionRow[] {
  return [...rows]
    .sort((a, b) => (b.mention.evidence?.length ?? 0) - (a.mention.evidence?.length ?? 0))
    .slice(0, limit);
}
const topMentions = topByEvidence(allMentionRows, 3);

const hreflang = hreflangAlternates(
  "thinkers",
  t.id,
  t.data.language,
  t.data.translations,
  Astro.site!.origin,
);

const treatment = t.data.portrait?.caricature
  ? { src: t.data.portrait.caricature, kind: "caricature" as const }
  : t.data.portrait?.ring_portrait
    ? { src: t.data.portrait.ring_portrait, kind: "ring" as const }
    : t.data.portrait?.photo
      ? { src: t.data.portrait.photo, kind: "photo" as const }
      : null;

const datesStr =
  t.data.birth_year && t.data.death_year
    ? `${t.data.birth_year}–${t.data.death_year}`
    : t.data.birth_year
      ? `b. ${t.data.birth_year}`
      : "";

// Bio source is editorial provenance. We surface it only when it's
// genuinely useful to a public reader — i.e., when the bio is an
// editorial feature article. The other values ("imported",
// "ai_drafted", "ai_drafted_stub", "canonical") are admin signals
// that should not appear in the public UI.
const bioSourceLabel =
  t.data.bio_source === "feature_article" ? "From feature article" : null;
---

<BaseLayout
  title={`${t.data.name.canonical} — Indian Liberals`}
  description={`Biographical profile of ${t.data.name.canonical}${datesStr ? ` (${datesStr})` : ""}.`}
  lang={t.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(t.data.translation_status)}
>
  <article
    class="mx-auto max-w-4xl px-6 py-12 md:py-16"
    data-pagefind-filter={`type:thinker,lang:${t.data.language}`}
    data-pagefind-meta={`tradition:${t.data.tradition}`}
  >
    <header class="border-b border-(--color-border) pb-10 mb-10 grid md:grid-cols-[auto_1fr] gap-8 items-start">
      {treatment && (
        <div class="w-40 md:w-48 aspect-[3/4] bg-(--color-bg-muted) rounded-sm overflow-hidden flex items-end justify-center">
          <img
            src={treatment.src}
            alt={`Portrait of ${t.data.name.canonical}`}
            width="288"
            height="384"
            class={treatment.kind === "ring" ? "w-full h-full object-cover" : "w-full h-full object-contain object-bottom"}
          />
        </div>
      )}
      <div>
        <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-2">
          {t.data.tradition.replace(/_/g, " ")}
        </p>
        <h1 class="text-(--color-fg) leading-tight">{t.data.name.canonical}</h1>
        {t.data.name.full && t.data.name.full !== t.data.name.canonical && (
          <p class="text-(--color-fg-muted) font-(family-name:--font-display) italic text-lg mt-1">
            {t.data.name.full}
          </p>
        )}
        {datesStr && (
          <p class="text-(--color-fg-muted) font-(family-name:--font-ui) mt-3 text-base">{datesStr}</p>
        )}
        {t.data.name.also_known_as.length > 0 && (
          <p class="text-(--color-fg-muted) text-sm mt-3 font-(family-name:--font-ui)">
            Also known as: {t.data.name.also_known_as.join(", ")}
          </p>
        )}
        {bioSourceLabel && (
          <p class="text-xs uppercase tracking-widest text-(--color-fg-muted) font-(family-name:--font-ui) mt-6">
            {bioSourceLabel}
          </p>
        )}
      </div>
    </header>

    <div class="prose-container">
      <div class="text-(--color-fg) leading-relaxed [&_p]:my-5 [&_p]:text-[1.0625rem] [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_a]:text-(--color-forest-700) [&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-6 [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted)">
        <Content />
      </div>
    </div>

    {(t.data.themes.length > 0 || t.data.affiliations.length > 0) && (
      <aside class="mt-12 pt-8 border-t border-(--color-border) grid md:grid-cols-2 gap-8 font-(family-name:--font-ui) text-sm">
        {t.data.themes.length > 0 && (
          <div>
            <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-3">Themes</h2>
            <ul class="flex flex-wrap gap-2">
              {t.data.themes.map((th) => (
                <li class="px-2.5 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded-full text-(--color-fg)">{th.replace(/_/g, " ")}</li>
              ))}
            </ul>
          </div>
        )}
        {t.data.affiliations.length > 0 && (
          <div>
            <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-3">Affiliations</h2>
            <ul class="space-y-1">
              {t.data.affiliations.map((a) => (
                <li><a href={`/organisations/${a}/`} class="text-(--color-forest-700)">{a.replace(/-/g, " ")}</a></li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    )}

    {/* ── Phase B: How this thinker is discussed in this archive ───── */}
    {hasPhaseBData && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          How {t.data.name.canonical} is discussed in this archive
        </h2>
        <div class="text-(--color-fg) text-base leading-relaxed space-y-3">
          {authorshipCount > 0 && (
            <p>
              Authored {authorshipCount} {authorshipCount === 1 ? "work" : "works"} in the archive.
            </p>
          )}
          {subjectMentions.length > 0 && (
            <p>
              Subject of {subjectMentions.length} profile {subjectMentions.length === 1 ? "piece" : "pieces"}
              {" — including "}
              {subjectMentions.slice(0, 3).map((row, i) => (
                <Fragment>
                  {i > 0 && (i === Math.min(subjectMentions.length, 3) - 1 ? ", and " : ", ")}
                  <a href={`/opinions/${row.entry.id}/`} class="text-(--color-forest-700) no-underline hover:underline">
                    {row.entry.data.title}
                  </a>
                </Fragment>
              ))}
              .
            </p>
          )}
          {allMentionRows.length > 0 && (
            <p>
              Referenced in {allMentionRows.length} other {allMentionRows.length === 1 ? "work" : "works"}
              {topMentions.length > 0 && (
                <Fragment>
                  {" — including "}
                  {topMentions.map((row, i) => (
                    <Fragment>
                      {i > 0 && (i === topMentions.length - 1 ? ", and " : ", ")}
                      <a href={`/${row.entry.collection}/${row.entry.id}/`} class="text-(--color-forest-700) no-underline hover:underline">
                        {row.entry.collection === "primary-works"
                          ? row.entry.data.title.main
                          : row.entry.data.title}
                      </a>
                    </Fragment>
                  ))}
                </Fragment>
              )}
              .
            </p>
          )}
          {allMentionRows.slice(0, 5).map((row) => (
            <p class="text-sm text-(--color-fg-muted) italic pl-3 border-l-2 border-(--color-saffron-200)">
              <span class="not-italic text-(--color-fg)">In <a href={`/${row.entry.collection}/${row.entry.id}/`} class="text-(--color-forest-700) no-underline hover:underline">
                {row.entry.collection === "primary-works" ? row.entry.data.title.main : row.entry.data.title}
              </a>:</span>{" "}
              {(row.mention.reasoning || "").split(/(?<=\.)\s+/)[0]}
            </p>
          ))}
        </div>
      </section>
    )}

    {/* ── Section 1: Works BY this thinker ────────────────────────── */}
    {authorshipCount > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          By {t.data.name.canonical} ({authorshipCount})
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {worksByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Primary works ({worksByThisThinker.length})</h3>
              <ul class="space-y-2">
                {worksByThisThinker.slice(0, 15).map((w) => (
                  <li>
                    <a href={`/primary-works/${w.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {w.data.title.main}
                      <span class="text-(--color-fg-muted) ml-1">· {w.data.publication?.year ?? "n.d."}</span>
                    </a>
                  </li>
                ))}
                {worksByThisThinker.length > 15 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {worksByThisThinker.length - 15} more</li>
                )}
              </ul>
            </div>
          )}
          {musingsByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Excerpts ({musingsByThisThinker.length})</h3>
              <ul class="space-y-2">
                {musingsByThisThinker.slice(0, 10).map((m) => (
                  <li>
                    <a href={`/musings/${m.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {m.data.title}
                    </a>
                  </li>
                ))}
                {musingsByThisThinker.length > 10 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {musingsByThisThinker.length - 10} more</li>
                )}
              </ul>
            </div>
          )}
          {opinionsByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Opinion pieces ({opinionsByThisThinker.length})</h3>
              <ul class="space-y-2">
                {opinionsByThisThinker.map((o) => (
                  <li>
                    <a href={`/opinions/${o.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {o.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {theprintByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">In ThePrint ({theprintByThisThinker.length})</h3>
              <ul class="space-y-2">
                {theprintByThisThinker.slice(0, 10).map((p) => (
                  <li>
                    <a href={p.data.theprint_url} target="_blank" rel="noopener canonical" class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {p.data.title}
                      <span aria-hidden class="text-(--color-fg-muted) ml-1">↗</span>
                    </a>
                  </li>
                ))}
                {theprintByThisThinker.length > 10 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {theprintByThisThinker.length - 10} more</li>
                )}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {/* ── Section 2: Profile pieces / interviews ABOUT this thinker ─── */}
    {aboutCount > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          About {t.data.name.canonical} ({aboutCount})
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {interviewsAbout.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Interviews ({interviewsAbout.length})</h3>
              <ul class="space-y-2">
                {interviewsAbout.map((i) => (
                  <li>
                    <a href={`/primary-works/${i.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {typeof i.data.title === "string" ? i.data.title : i.data.title?.en ?? i.id}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {opinionsAbout.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Profile pieces ({opinionsAbout.length})</h3>
              <ul class="space-y-2">
                {opinionsAbout.map((o) => {
                  const tm = mentionFor(o, t.id);
                  const passages = (tm?.role === 'subject' ? tm.key_passages ?? [] : []).slice(0, 2);
                  return (
                    <li>
                      <a href={`/opinions/${o.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                        {o.data.title}
                      </a>
                      {passages.length > 0 && (
                        <ul class="mt-1 space-y-1 ml-2">
                          {passages.map((kp: any) => (
                            <li class="text-xs italic text-(--color-fg-muted) pl-2 border-l border-(--color-saffron-200)">
                              "{kp.quote}"
                              {kp.what_it_shows && <span class="not-italic text-(--color-fg-muted) ml-1">— {kp.what_it_shows}</span>}
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {/* ── Section 3: Mentioned in (Phase A: only structured related_thinkers; Phase B will populate from in-prose NER) ── */}
    {mentionCount > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          Mentioned in ({mentionCount})
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {workMentions.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Primary works ({workMentions.length})</h3>
              <ul class="space-y-2">
                {workMentions.slice(0, 15).map((w) => {
                  const tm = mentionFor(w, t.id);
                  const quotes = (tm?.evidence ?? []).slice(0, 2);
                  return (
                    <li>
                      <a href={`/primary-works/${w.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                        {w.data.title.main}
                        <span class="text-(--color-fg-muted) ml-1">· {w.data.publication?.year ?? "n.d."}</span>
                      </a>
                      {quotes.length > 0 && (
                        <ul class="mt-1 space-y-1 ml-2">
                          {quotes.map((ev: any) => (
                            <li class="text-xs italic text-(--color-fg-muted) pl-2 border-l border-(--color-saffron-200)">
                              "{ev.quote}"
                              {ev.context && <span class="not-italic text-(--color-fg-muted) ml-1">— {ev.context}</span>}
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  );
                })}
                {workMentions.length > 15 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {workMentions.length - 15} more</li>
                )}
              </ul>
            </div>
          )}
          {opinionMentions.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Opinion pieces ({opinionMentions.length})</h3>
              <ul class="space-y-2">
                {opinionMentions.slice(0, 10).map((o) => {
                  const tm = mentionFor(o, t.id);
                  const quotes = (tm?.evidence ?? []).slice(0, 2);
                  return (
                    <li>
                      <a href={`/opinions/${o.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                        {o.data.title}
                      </a>
                      {quotes.length > 0 && (
                        <ul class="mt-1 space-y-1 ml-2">
                          {quotes.map((ev: any) => (
                            <li class="text-xs italic text-(--color-fg-muted) pl-2 border-l border-(--color-saffron-200)">
                              "{ev.quote}"
                              {ev.context && <span class="not-italic text-(--color-fg-muted) ml-1">— {ev.context}</span>}
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          )}
          {musingMentions.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Excerpts ({musingMentions.length})</h3>
              <ul class="space-y-2">
                {musingMentions.slice(0, 10).map((m) => {
                  const tm = mentionFor(m, t.id);
                  const quotes = (tm?.evidence ?? []).slice(0, 2);
                  return (
                    <li>
                      <a href={`/musings/${m.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                        {m.data.title}
                      </a>
                      {quotes.length > 0 && (
                        <ul class="mt-1 space-y-1 ml-2">
                          {quotes.map((ev: any) => (
                            <li class="text-xs italic text-(--color-fg-muted) pl-2 border-l border-(--color-saffron-200)">
                              "{ev.quote}"
                              {ev.context && <span class="not-italic text-(--color-fg-muted) ml-1">— {ev.context}</span>}
                            </li>
                          ))}
                        </ul>
                      )}
                    </li>
                  );
                })}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    <RelatedSection collection="thinkers" slug={t.id} viewerLang={t.data.language} />
  </article>
</BaseLayout>
