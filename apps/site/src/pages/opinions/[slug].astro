---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE } from "~/lib/i18n";
import OpinionDetail from "~/components/OpinionDetail.astro";

export async function getStaticPaths() {
  const opinions = await getCollection(
    "opinions",
    (o) => !o.data.draft && o.data.language === DEFAULT_LOCALE,
  );
  return opinions.map((o) => ({ params: { slug: o.id }, props: { o } }));
}

const { o } = Astro.props;
---

<OpinionDetail entry={o} />
