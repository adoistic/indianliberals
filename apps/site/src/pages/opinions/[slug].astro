---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { hreflangAlternates, shouldNoindex } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";
import PeopleInPiece from "~/components/PeopleInPiece.astro";
import ContributorCard from "~/components/ContributorCard.astro";

export async function getStaticPaths() {
  const opinions = await getCollection(
    "opinions",
    (o) => !o.data.draft && o.data.language === "en",
  );
  return opinions.map((o) => ({ params: { slug: o.id }, props: { o } }));
}

const { o } = Astro.props;
const { Content } = await render(o);

const hreflang = hreflangAlternates(
  "opinions",
  o.id,
  o.data.language,
  o.data.translations,
  Astro.site!.origin,
);

// Resolve byline thinker (if any) and subject (profile pieces).
const authorEntry = o.data.author ? await getEntry(o.data.author) : null;
const subjectEntry = o.data.subject ? await getEntry(o.data.subject) : null;

const authorSlugs = authorEntry ? [authorEntry.id] : [];
const subjectSlugs = subjectEntry ? [subjectEntry.id] : [];
const mentionSlugs = (o.data.thinker_mentions ?? [])
  .map((mn: any) => (typeof mn.thinker === "string" ? mn.thinker : mn.thinker?.id))
  .filter(Boolean);
---

<BaseLayout
  title={`${o.data.title} — Indian Liberals`}
  lang={o.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(o.data.translation_status)}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16" data-pagefind-filter={`type:opinion,lang:${o.data.language}`}>
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        Opinion
      </p>
      <h1 class="text-(--color-fg) leading-tight">{o.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(o.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}
        {authorEntry ? (
          <>
            {" · By "}
            <a href={`/contributors/${authorEntry.id}/`} class="text-(--color-fg) font-semibold no-underline hover:text-(--color-forest-700)">
              {authorEntry.data.name.canonical}
            </a>
          </>
        ) : o.data.author_name && o.data.author_name !== "Editorial Team" && o.data.author_name !== "CCS Editorial Team" ? (
          <span> · {o.data.author_name}</span>
        ) : null}
        {subjectEntry && (
          <>
            {" · About "}
            <a href={`/thinkers/${subjectEntry.id}/`} class="text-(--color-fg) font-semibold no-underline hover:text-(--color-forest-700)">
              {subjectEntry.data.name.canonical}
            </a>
          </>
        )}
      </p>
      {o.data.key_concepts && o.data.key_concepts.length > 0 && (
        <ul class="flex flex-wrap gap-1.5 mt-3 not-prose">
          {o.data.key_concepts.map((kc) => (
            <li>
              <a
                href={`/opinions/?key_concept=${encodeURIComponent(kc)}`}
                class="inline-block px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg-muted) hover:border-(--color-fg) hover:text-(--color-fg) transition-colors font-(family-name:--font-ui)"
              >
                {kc.replace(/-/g, " ")}
              </a>
            </li>
          ))}
        </ul>
      )}
    </header>
    <div class="prose-container text-(--color-fg) leading-relaxed text-[1.0625rem] [&_p]:my-5 [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_a]:text-(--color-forest-700) [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted) [&_blockquote]:my-5">
      <Content />
    </div>

    {authorEntry && (
      <ContributorCard contributor={authorEntry} variant="inline" />
    )}

    <PeopleInPiece authorSlugs={authorSlugs} subjectSlugs={subjectSlugs} mentionSlugs={mentionSlugs} />

    <RelatedSection collection="opinions" slug={o.id} viewerLang={o.data.language} />
  </article>
</BaseLayout>
