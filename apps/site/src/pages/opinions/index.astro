---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { inlineMd } from "~/lib/inline-md";

const opinions = (await getCollection("opinions", (o) => !o.data.draft && o.data.language === "en")).sort(
  (a, b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate),
);

// Facet vocabularies for the filter chips.
const themeCounts = new Map<string, number>();
const decadeCounts = new Map<number, number>();
const kindCounts = new Map<string, number>();
const periodCounts = new Map<string, number>();
const stanceCounts = new Map<string, number>();
const scaleCounts = new Map<string, number>();
const placeCounts = new Map<string, number>();
const keyConceptCounts = new Map<string, number>();
for (const o of opinions) {
  for (const th of o.data.themes ?? []) themeCounts.set(th, (themeCounts.get(th) ?? 0) + 1);
  const y = new Date(o.data.pubDate).getFullYear();
  const dec = Math.floor(y / 10) * 10;
  decadeCounts.set(dec, (decadeCounts.get(dec) ?? 0) + 1);
  if (o.data.kind) kindCounts.set(o.data.kind, (kindCounts.get(o.data.kind) ?? 0) + 1);
  if (o.data.period_window) periodCounts.set(o.data.period_window, (periodCounts.get(o.data.period_window) ?? 0) + 1);
  if (o.data.stance) stanceCounts.set(o.data.stance, (stanceCounts.get(o.data.stance) ?? 0) + 1);
  const sc = o.data.geographic_scope?.scale;
  if (sc) scaleCounts.set(sc, (scaleCounts.get(sc) ?? 0) + 1);
  for (const p of o.data.geographic_scope?.places ?? []) {
    placeCounts.set(p, (placeCounts.get(p) ?? 0) + 1);
  }
  for (const c of o.data.key_concepts ?? []) {
    keyConceptCounts.set(c, (keyConceptCounts.get(c) ?? 0) + 1);
  }
}
// Drop bucket-label leftovers from themes facet (defensive — Step 0 should have already cleared them).
const BUCKET_DROP = new Set(["events", "opinions"]);
const themeOptions = [...themeCounts.entries()]
  .filter(([t]) => !BUCKET_DROP.has(t))
  .sort((a, b) => b[1] - a[1])
  .slice(0, 30);
const decadeOptions = [...decadeCounts.entries()].sort((a, b) => b[0] - a[0]);
// Era ordering: chronological
const PERIOD_ORDER = ["pre-independence", "nehruvian-era", "late-license-raj", "reform-era", "post-reform"];
const periodOptions = PERIOD_ORDER
  .filter((p) => periodCounts.has(p))
  .map((p) => [p, periodCounts.get(p) as number] as [string, number]);
const kindOptions = [...kindCounts.entries()].sort((a, b) => b[1] - a[1]);
const stanceOptions = [...stanceCounts.entries()].sort((a, b) => b[1] - a[1]);
const scaleOptions = [...scaleCounts.entries()].sort((a, b) => b[1] - a[1]);
const placeOptions = [...placeCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 30);
const keyConceptOptions = [...keyConceptCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 30);
---

<BaseLayout
  title="Opinions — Indian Liberals"
  description="First-party opinion pieces and commentary from the Indian liberal tradition."
>
  <section class="border-b border-(--color-border)">
    <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        Opinions
      </p>
      <h1 class="text-(--color-fg) mb-4">First-party opinion pieces</h1>
      <p class="text-(--color-fg-muted) leading-relaxed max-w-prose">
        Contemporary commentary published on Indian Liberals: feature essays, reviews of historical episodes, and reflections on figures in the tradition.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-12 md:grid md:grid-cols-[220px_1fr] md:gap-10">
    {/* Filter sidebar */}
    <aside
      class="
        font-(family-name:--font-ui) text-sm mb-8 md:mb-0
        md:sticky md:top-[5.5rem] md:self-start
        md:max-h-[calc(100vh-6rem)] md:overflow-y-auto md:pr-2
      "
      aria-label="Filter opinions"
    >
      <div class="flex items-baseline justify-between gap-3 mb-3 pb-3 border-b border-(--color-border)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted)">Filter</h2>
        <button id="o-reset" type="button" class="text-[10px] uppercase tracking-wider text-(--color-saffron-700) font-semibold hover:text-(--color-fg) hidden">
          Reset
        </button>
      </div>
      <p class="text-xs text-(--color-fg-muted) mb-5">
        Showing <strong id="o-counter-visible" class="text-(--color-fg)">{opinions.length}</strong> of <strong>{opinions.length}</strong>
      </p>

      <div class="mb-5">
        <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Decade</h3>
        <ul class="flex flex-wrap gap-1.5">
          {decadeOptions.map(([d, n]) => (
            <li>
              <button
                type="button"
                data-filter-decade={String(d)}
                class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
              >
                {d}s <span class="opacity-70">({n})</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      {kindOptions.length > 0 && (
        <div class="mb-5">
          <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Kind</h3>
          <ul class="flex flex-wrap gap-1.5">
            {kindOptions.map(([k, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-kind={k}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {k.replace(/-/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      )}

      {periodOptions.length > 0 && (
        <div class="mb-5">
          <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Period</h3>
          <ul class="flex flex-wrap gap-1.5">
            {periodOptions.map(([p, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-period={p}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {p.replace(/-/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      )}

      {stanceOptions.length > 0 && (
        <div class="mb-5">
          <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Stance</h3>
          <ul class="flex flex-wrap gap-1.5">
            {stanceOptions.map(([s, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-stance={s}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {s.replace(/-/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      )}

      {scaleOptions.length > 0 && (
        <div class="mb-5">
          <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Scale</h3>
          <ul class="flex flex-wrap gap-1.5">
            {scaleOptions.map(([s, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-scale={s}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {s.replace(/-/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </div>
      )}

      {placeOptions.length > 0 && (
        <details class="mb-5">
          <summary class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) cursor-pointer select-none hover:text-(--color-fg) mb-2">Place ▾</summary>
          <ul class="flex flex-wrap gap-1.5">
            {placeOptions.map(([p, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-place={p}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {p.replace(/-/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </details>
      )}

      {keyConceptOptions.length > 0 && (
        <details class="mb-5">
          <summary class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) cursor-pointer select-none hover:text-(--color-fg) mb-2">Key concepts ▾</summary>
          <ul class="flex flex-wrap gap-1.5">
            {keyConceptOptions.map(([kc, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-key-concept={kc}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {kc.replace(/-/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </details>
      )}

      {themeOptions.length > 0 && (
        <details class="mb-5" open>
          <summary class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) cursor-pointer select-none hover:text-(--color-fg) mb-2">Themes ▾</summary>
          <ul class="flex flex-wrap gap-1.5">
            {themeOptions.map(([th, n]) => (
              <li>
                <button
                  type="button"
                  data-filter-theme={th}
                  class="o-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                >
                  {th.replace(/[_-]/g, " ")} <span class="opacity-70">({n})</span>
                </button>
              </li>
            ))}
          </ul>
        </details>
      )}
    </aside>

    {/* Listing column */}
    <div class="min-w-0">
      <ul class="divide-y divide-(--color-border)" id="o-list">
        {opinions.map((o) => {
          const y = new Date(o.data.pubDate).getFullYear();
          const dec = Math.floor(y / 10) * 10;
          return (
            <li
              class="o-item py-6"
              data-decade={String(dec)}
              data-themes={(o.data.themes ?? []).join(" ")}
              data-kind={o.data.kind ?? ""}
              data-period={o.data.period_window ?? ""}
              data-stance={o.data.stance ?? ""}
              data-scale={o.data.geographic_scope?.scale ?? ""}
              data-places={(o.data.geographic_scope?.places ?? []).join(" ")}
              data-key-concepts={(o.data.key_concepts ?? []).join(" ")}
            >
              <a href={`/opinions/${o.id}/`} class="block no-underline group">
                <p class="text-xs text-(--color-fg-muted) font-(family-name:--font-ui) mb-1">
                  {new Date(o.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}
                  {o.data.author_name && o.data.author_name !== "CCS Editorial Team" && (<><span> · </span>{o.data.author_name}</>)}
                </p>
                <h2 class="font-(family-name:--font-display) text-(--color-fg) group-hover:text-(--color-saffron-700) transition-colors text-xl leading-snug">
                  {o.data.title}
                </h2>
                {o.data.pull_quote && (
                  <p
                    class="text-sm text-(--color-fg-muted) italic mt-2 line-clamp-2"
                    set:html={`&ldquo;${inlineMd(o.data.pull_quote)}&rdquo;`}
                  />
                )}
              </a>
            </li>
          );
        })}
      </ul>
      <p id="o-empty" class="hidden text-center py-12 text-(--color-fg-muted) font-(family-name:--font-ui)">
        No opinions match the current filter. Try removing some criteria.
      </p>
    </div>
  </div>

  <script is:inline>
    (function () {
      const state = {
        decade: new Set(),
        theme: new Set(),
        kind: new Set(),
        period: new Set(),
        stance: new Set(),
        scale: new Set(),
        place: new Set(),
        keyConcept: new Set(),
      };
      const items = Array.from(document.querySelectorAll('.o-item'));
      const totalEl = document.getElementById('o-counter-visible');
      const resetBtn = document.getElementById('o-reset');
      const emptyEl = document.getElementById('o-empty');
      const ACTIVE = ['bg-(--color-saffron-500)', 'text-white', 'border-(--color-saffron-500)'];
      const IDLE = ['bg-(--color-bg)', 'text-(--color-fg)', 'border-(--color-border)'];

      const FACET_KEYS = {
        decade: 'decade',
        theme: 'themes',
        kind: 'kind',
        period: 'period',
        stance: 'stance',
        scale: 'scale',
        place: 'places',
        keyConcept: 'keyConcepts',
      };

      function applyFilters() {
        let visible = 0;
        for (const li of items) {
          let show = true;
          for (const [facet, set] of Object.entries(state)) {
            if (set.size === 0) continue;
            const dsKey = FACET_KEYS[facet];
            const raw = li.dataset[dsKey] || '';
            const isList = ['themes', 'places', 'keyConcepts'].includes(dsKey);
            if (isList) {
              const parts = raw.split(/\s+/).filter(Boolean);
              if (!parts.some((p) => set.has(p))) { show = false; break; }
            } else {
              if (!set.has(raw)) { show = false; break; }
            }
          }
          li.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        if (totalEl) totalEl.textContent = String(visible);
        if (emptyEl) emptyEl.classList.toggle('hidden', visible !== 0);
        if (resetBtn) {
          const anyActive = Object.values(state).some((s) => s.size > 0);
          resetBtn.classList.toggle('hidden', !anyActive);
        }
        syncURL();
      }

      function toggle(btn, facet, value) {
        const set = state[facet];
        if (set.has(value)) {
          set.delete(value);
          IDLE.forEach((c) => btn.classList.add(c));
          ACTIVE.forEach((c) => btn.classList.remove(c));
        } else {
          set.add(value);
          ACTIVE.forEach((c) => btn.classList.add(c));
          IDLE.forEach((c) => btn.classList.remove(c));
        }
        applyFilters();
      }

      // URL param namespace: ?theme=, ?kind=, ?period=, ?stance=, ?scale=, ?place=, ?key_concept=, ?decade=
      const URL_KEYS = {
        theme: 'theme',
        kind: 'kind',
        period: 'period',
        stance: 'stance',
        scale: 'scale',
        place: 'place',
        keyConcept: 'key_concept',
        decade: 'decade',
      };

      function parseInitialParamsFromURL() {
        const usp = new URLSearchParams(window.location.search);
        for (const [facet, paramName] of Object.entries(URL_KEYS)) {
          const v = usp.get(paramName);
          if (!v) continue;
          for (const piece of v.split(',').map((s) => s.trim()).filter(Boolean)) {
            state[facet].add(piece);
          }
        }
        // Apply ACTIVE styling to matching chips
        document.querySelectorAll('.o-chip').forEach((btn) => {
          let activated = false;
          for (const [facet, attr] of Object.entries({
            kind: 'filterKind', decade: 'filterDecade', theme: 'filterTheme',
            period: 'filterPeriod', stance: 'filterStance', scale: 'filterScale',
            place: 'filterPlace', keyConcept: 'filterKeyConcept',
          })) {
            const v = btn.dataset[attr];
            if (v && state[facet].has(v)) {
              activated = true;
              break;
            }
          }
          if (activated) {
            ACTIVE.forEach((c) => btn.classList.add(c));
            IDLE.forEach((c) => btn.classList.remove(c));
          }
        });
      }

      function syncURL() {
        const usp = new URLSearchParams();
        for (const [facet, paramName] of Object.entries(URL_KEYS)) {
          const set = state[facet];
          if (set.size > 0) usp.set(paramName, [...set].join(','));
        }
        const qs = usp.toString();
        const newURL = window.location.pathname + (qs ? '?' + qs : '');
        window.history.replaceState(null, '', newURL);
      }

      document.querySelectorAll('.o-chip').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (btn.dataset.filterDecade) toggle(btn, 'decade', btn.dataset.filterDecade);
          else if (btn.dataset.filterTheme) toggle(btn, 'theme', btn.dataset.filterTheme);
          else if (btn.dataset.filterKind) toggle(btn, 'kind', btn.dataset.filterKind);
          else if (btn.dataset.filterPeriod) toggle(btn, 'period', btn.dataset.filterPeriod);
          else if (btn.dataset.filterStance) toggle(btn, 'stance', btn.dataset.filterStance);
          else if (btn.dataset.filterScale) toggle(btn, 'scale', btn.dataset.filterScale);
          else if (btn.dataset.filterPlace) toggle(btn, 'place', btn.dataset.filterPlace);
          else if (btn.dataset.filterKeyConcept) toggle(btn, 'keyConcept', btn.dataset.filterKeyConcept);
        });
      });

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          for (const s of Object.values(state)) s.clear();
          document.querySelectorAll('.o-chip').forEach((btn) => {
            ACTIVE.forEach((c) => btn.classList.remove(c));
            IDLE.forEach((c) => btn.classList.add(c));
          });
          applyFilters();
        });
      }

      parseInitialParamsFromURL();
      applyFilters();
    })();
  </script>
</BaseLayout>
