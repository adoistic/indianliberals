---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE } from "~/lib/i18n";
import InterviewDetail from "~/components/InterviewDetail.astro";

export async function getStaticPaths() {
  const interviews = await getCollection(
    "interviews",
    (i) => !i.data.draft && i.data.language === DEFAULT_LOCALE,
  );
  return interviews.map((i) => ({ params: { slug: i.id }, props: { i } }));
}

const { i } = Astro.props;
---

<InterviewDetail entry={i} />
