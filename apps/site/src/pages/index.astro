---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allThinkers = await getCollection("thinkers", (t) => !t.data.draft);

const featuredThinkers = allThinkers
  .filter((t) => t.data.portrait?.caricature || t.data.portrait?.ring_portrait)
  .slice(0, 6);

// Latest 6 ThePrint articles — links go out to theprint.in (the canonical
// home). The federated column updates daily via the theprint-ingest worker
// (apps/theprint-ingest), so this list reflects the freshest pieces in
// the "Indian Liberals Matter" column on each build.
const latestTheprint = (await getCollection("theprint-mirror", (p) => !p.data.draft))
  .sort((a, b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate))
  .slice(0, 6);
---

<BaseLayout>
  <!-- Hero -->
  <section class="border-b border-(--color-border)">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28 grid md:grid-cols-[1fr_auto] gap-12 items-center">
      <div>
        <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-4">
          An online archive of Indian liberal works
        </p>
        <h1 class="text-(--color-fg) max-w-2xl">
          A modern home for the Indian liberal tradition.
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-(--color-fg-muted) max-w-prose">
          Primary works by historically significant Indian liberal thinkers, alongside thinker profiles, organisation pages, curated excerpts, opinion pieces, interviews, and a federated feed from ThePrint&rsquo;s &ldquo;Indian Liberals Matter&rdquo; column.
        </p>
        <div class="mt-8 flex flex-wrap gap-3 font-(family-name:--font-ui)">
          <a
            href="/thinkers/"
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-(--color-fg) text-white! rounded-full text-sm font-semibold no-underline hover:bg-(--color-forest-700) transition-colors"
          >
            Browse thinkers <span aria-hidden>→</span>
          </a>
          <a
            href="/about/"
            class="inline-flex items-center gap-2 px-5 py-2.5 border border-(--color-border) rounded-full text-sm font-semibold no-underline text-(--color-fg) hover:border-(--color-fg) transition-colors"
          >
            About this archive
          </a>
        </div>
      </div>
      <div class="hidden md:block">
        <img
          src="/brand/brand-mark-crane.png"
          alt="The Indian Liberals brand mark — an origami crane in the Indian tricolor"
          width="220"
          height="220"
          class="w-44 h-44 lg:w-56 lg:h-56"
        />
      </div>
    </div>
  </section>

  <!-- Featured thinkers -->
  {featuredThinkers.length > 0 && (
    <section class="border-b border-(--color-border)">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
          <div>
            <h2 class="text-(--color-fg)">Featured thinkers</h2>
            <p class="text-(--color-fg-muted) mt-2 max-w-prose">
              Figures who shaped the Indian liberal tradition — from Raja Ram Mohan Roy through the Swatantra-era classical liberals to contemporary commentators.
            </p>
          </div>
          <a href="/thinkers/" class="text-sm font-(family-name:--font-ui) font-semibold no-underline text-(--color-forest-700) hover:text-(--color-fg)">
            All thinkers →
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
          {featuredThinkers.map((t) => (
            <a href={`/thinkers/${t.id}/`} class="group no-underline block">
              <div class="aspect-[3/4] bg-(--color-bg-muted) border border-(--color-border) rounded-sm overflow-hidden flex items-end justify-center transition-shadow group-hover:shadow-md">
                {t.data.portrait?.caricature && (
                  <img src={t.data.portrait.caricature} alt="" width="240" height="320" loading="lazy" class="w-full h-full object-contain object-bottom group-hover:scale-[1.02] transition-transform duration-300" />
                )}
                {t.data.portrait?.ring_portrait && !t.data.portrait?.caricature && (
                  <img src={t.data.portrait.ring_portrait} alt="" width="240" height="320" loading="lazy" class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />
                )}
              </div>
              <h3 class="mt-3 font-(family-name:--font-display) font-semibold text-(--color-fg) group-hover:text-(--color-saffron-700) transition-colors leading-tight">{t.data.name.canonical}</h3>
              {t.data.birth_year && (
                <p class="text-sm text-(--color-fg-muted) font-(family-name:--font-ui)">
                  {t.data.birth_year}–{t.data.death_year ?? ""}
                </p>
              )}
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- What's in the archive -->
  <section class="border-b border-(--color-border) bg-(--color-bg-muted)">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-(--color-fg) mb-8">What&rsquo;s in the archive</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 font-(family-name:--font-ui)">
        {[
          { title: "Primary works", desc: "Books, pamphlets, essays, and speeches by Indian liberal thinkers — served as PDFs with rich AI-extracted metadata, summaries, and key points.", href: "/primary-works/" },
          { title: "Periodicals", desc: "The Indian Libertarian, Freedom First, and other archives — indexed at the issue level with metadata and AI summaries.", href: "/periodicals/" },
          { title: "Thinker profiles", desc: "Biographies and bibliographies for each thinker, cross-linked to their works and organisations.", href: "/thinkers/" },
          { title: "Curated excerpts", desc: "Cleaned passages from primary works — paragraph-addressable, full-text searchable, citable.", href: "/musings/" },
        ].map((card) => (
          <a href={card.href} class="block bg-(--color-bg) border border-(--color-border) rounded p-5 no-underline hover:shadow-md hover:-translate-y-0.5 transition-all">
            <h3 class="font-(family-name:--font-display) font-semibold text-(--color-fg) mb-2">{card.title}</h3>
            <p class="text-sm text-(--color-fg-muted) leading-relaxed">{card.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest from ThePrint federated column — links go out to theprint.in -->
  {latestTheprint.length > 0 && (
    <section class="border-b border-(--color-border)">
      <div class="mx-auto max-w-6xl px-6 py-16">
        <div class="flex items-end justify-between mb-8 flex-wrap gap-4">
          <div>
            <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-2">
              From the federated column
            </p>
            <h2 class="text-(--color-fg)">Latest from ThePrint</h2>
            <p class="text-(--color-fg-muted) mt-2 max-w-prose">
              A regular series on ThePrint surfacing the Indian liberal tradition for a contemporary readership. Each piece opens at <a href="https://theprint.in/category/opinion/indian-liberals-matter/" class="text-(--color-forest-700)">theprint.in</a>.
            </p>
          </div>
          <a href="/theprint-mirror/" class="text-sm font-(family-name:--font-ui) font-semibold no-underline text-(--color-forest-700) hover:text-(--color-fg)">
            See all →
          </a>
        </div>
        <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestTheprint.map((p) => (
            <li>
              <a
                href={p.data.theprint_url}
                target="_blank"
                rel="noopener canonical"
                class="block h-full p-5 bg-(--color-bg) border border-(--color-border) rounded no-underline hover:border-(--color-fg) hover:shadow-sm transition-all group"
              >
                <p class="text-xs uppercase tracking-wider text-(--color-fg-muted) font-(family-name:--font-ui) mb-2">
                  {new Date(p.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" })} · {p.data.author_name}
                </p>
                <h3 class="font-(family-name:--font-display) font-semibold text-(--color-fg) group-hover:text-(--color-saffron-700) transition-colors leading-snug">
                  {p.data.title}
                  <span aria-hidden class="inline-block ml-1 text-(--color-fg-muted) text-sm">↗</span>
                </h3>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  <!-- For researchers and AI -->
  <section>
    <div class="mx-auto max-w-6xl px-6 py-16 grid md:grid-cols-2 gap-12">
      <div>
        <p class="text-xs uppercase tracking-widest text-(--color-forest-700) font-(family-name:--font-ui) font-semibold mb-3">
          For researchers and AI agents
        </p>
        <h2 class="text-(--color-fg) mb-4">A citation-grade source you can trust.</h2>
        <p class="text-(--color-fg-muted) leading-relaxed mb-4">
          Every page has a <code class="font-(family-name:--font-mono) text-sm bg-(--color-bg-muted) px-1.5 py-0.5 rounded">.md</code> sibling for machine readers. The corpus is indexed at <code class="font-(family-name:--font-mono) text-sm bg-(--color-bg-muted) px-1.5 py-0.5 rounded">/llms.txt</code> and <code class="font-(family-name:--font-mono) text-sm bg-(--color-bg-muted) px-1.5 py-0.5 rounded">/llms-full.txt</code> following the llms.txt spec.
        </p>
        <p class="text-(--color-fg-muted) leading-relaxed">
          A Model Context Protocol server at <a href="https://mcp.indianliberals.in" class="text-(--color-forest-700)">mcp.indianliberals.in</a> lets your LLM client query the archive directly — see <a href="/AGENTS.md" class="text-(--color-forest-700)">/AGENTS.md</a> for the schema and citation rules.
        </p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
          The two-tier model
        </p>
        <h2 class="text-(--color-fg) mb-4">Honest about what we know.</h2>
        <p class="text-(--color-fg-muted) leading-relaxed mb-4">
          Curated excerpts, opinion pieces, interviews, and profiles are fully searchable and paragraph-citable.
        </p>
        <p class="text-(--color-fg-muted) leading-relaxed">
          Primary-work PDFs surface with rich metadata and AI-generated summaries — paragraph-level citation inside the original works is deferred to a future engagement, when vision-language layout reconstruction is reliable enough to clear editorial review.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
