---
// Per-article landing page for an Indian Liberals Matter ThePrint piece.
//
// HUMAN view: minimal — title, byline (linking to thinker bio when
// resolved), date, and a prominent "Read on ThePrint" CTA. We do NOT
// render the article body for human readers; canonical content lives on
// theprint.in and that's where readers should go. The page sets
// noindex so search engines don't surface this stub.
//
// AI agents read the full body via the sibling endpoint at
// `/theprint-mirror/<slug>.md` — that's the route that fulfils the
// "AI-readable, human-redirected" intent.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, getEntry } from "astro:content";
import { hreflangAlternates } from "~/lib/i18n";

export async function getStaticPaths() {
  const posts = await getCollection("theprint-mirror", (p) => !p.data.draft);
  return posts.map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;

const hreflang = hreflangAlternates(
  "theprint-mirror",
  p.id,
  p.data.language,
  p.data.translations,
  Astro.site!.origin,
);

const bylineRefs = p.data.related_thinkers ?? [];
const bylineEntry = bylineRefs.length > 0 ? await getEntry(bylineRefs[0]) : null;
---

<BaseLayout
  title={`${p.data.title} — ThePrint mirror — Indian Liberals`}
  description={`Mirror of ThePrint piece by ${p.data.author_name}, published ${new Date(p.data.pubDate).toLocaleDateString("en-IN")}.`}
  lang={p.data.language}
  hreflang={hreflang}
  noindex={p.data.noindex}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16" data-pagefind-filter={`type:theprint-mirror,lang:${p.data.language}`}>
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        ThePrint federated mirror
      </p>
      <h1 class="text-(--color-fg) leading-tight">{p.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(p.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })} ·{" "}
        By{" "}
        {bylineEntry ? (
          <a href={`/thinkers/${bylineEntry.id}/`} class="text-(--color-forest-700) font-semibold">
            {bylineEntry.data.name.canonical}
          </a>
        ) : (
          p.data.author_name
        )}
      </p>
    </header>

    {/* Outbound CTA — the canonical article lives on theprint.in; readers
        go there. We deliberately do not render the body for humans. */}
    <div class="text-center py-8">
      <a
        href={p.data.theprint_url}
        target="_blank"
        rel="noopener canonical"
        class="inline-flex items-center gap-2 px-6 py-3 bg-(--color-fg) text-(--color-bg) rounded-full text-sm font-semibold font-(family-name:--font-ui) no-underline hover:bg-(--color-forest-700) transition-colors"
      >
        Read the full article on ThePrint
        <span aria-hidden>↗</span>
      </a>
      {p.data.themes.length > 0 && (
        <ul class="mt-6 flex flex-wrap gap-2 justify-center font-(family-name:--font-ui) text-xs">
          {p.data.themes.map((th) => (
            <li class="px-2.5 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded-full text-(--color-fg-muted)">
              {th.replace(/-/g, " ")}
            </li>
          ))}
        </ul>
      )}
    </div>

    <footer class="mt-8 pt-6 border-t border-(--color-border) text-xs text-(--color-fg-muted) font-(family-name:--font-ui) text-center">
      <p>
        Canonical version: <a href={p.data.theprint_url} class="text-(--color-forest-700)" target="_blank" rel="noopener canonical">{p.data.theprint_url}</a>.
        This page is for navigation only — full article body is on ThePrint
        (and available to AI agents via the <code>.md</code> sibling).
      </p>
    </footer>
  </article>
</BaseLayout>
