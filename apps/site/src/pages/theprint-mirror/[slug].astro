---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { hreflangAlternates } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";

export async function getStaticPaths() {
  // ThePrint mirror is mostly English — but we still pass language for SEO.
  const posts = await getCollection("theprint-mirror", (p) => !p.data.draft);
  return posts.map((p) => ({ params: { slug: p.id }, props: { p } }));
}

const { p } = Astro.props;
const { Content } = await render(p);

const hreflang = hreflangAlternates(
  "theprint-mirror",
  p.id,
  p.data.language,
  p.data.translations,
  Astro.site!.origin,
);
---

<BaseLayout
  title={`${p.data.title} — ThePrint mirror — Indian Liberals`}
  description={`Mirror of ThePrint piece by ${p.data.author_name}, published ${new Date(p.data.pubDate).toLocaleDateString("en-IN")}.`}
  lang={p.data.language}
  hreflang={hreflang}
  noindex={p.data.noindex}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16" data-pagefind-filter={`type:theprint-mirror,lang:${p.data.language}`}>
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        ThePrint federated mirror
      </p>
      <h1 class="text-(--color-fg) leading-tight">{p.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(p.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })} · By {p.data.author_name}
      </p>
      <a
        href={p.data.theprint_url}
        class="mt-4 inline-flex items-center gap-1.5 text-sm font-(family-name:--font-ui) text-(--color-forest-700) no-underline hover:underline"
        rel="canonical noopener"
      >
        Read on ThePrint <span aria-hidden>↗</span>
      </a>
    </header>
    <div class="prose-container text-(--color-fg) leading-relaxed text-[1.0625rem] [&_p]:my-5 [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_a]:text-(--color-forest-700) [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted) [&_blockquote]:my-5 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:my-5">
      <Content />
    </div>
    <footer class="mt-12 pt-6 border-t border-(--color-border) text-sm text-(--color-fg-muted) font-(family-name:--font-ui)">
      <p>
        Originally published on <a href={p.data.theprint_url} class="text-(--color-forest-700)" rel="canonical noopener">ThePrint</a>.
        Mirrored here for AI-agent readability. The canonical version is on ThePrint and retains all SEO weight; this page is set to <code>noindex</code>.
      </p>
    </footer>

    <RelatedSection collection="theprint-mirror" slug={p.id} viewerLang={p.data.language} />
  </article>
</BaseLayout>
