---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("theprint-mirror", (p) => !p.data.draft)).sort(
  (a, b) => +new Date(b.data.pubDate) - +new Date(a.data.pubDate),
);
---

<BaseLayout
  title="ThePrint federated archive — Indian Liberals"
  description="The Indian Liberals Matter column from ThePrint, mirrored on-site for AI agents. Canonical SEO weight stays with ThePrint."
  noindex={true}
>
  <section class="border-b border-(--color-border)">
    <div class="mx-auto max-w-6xl px-6 py-12 md:py-16">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        ThePrint federated archive
      </p>
      <h1 class="text-(--color-fg) mb-4">Indian Liberals Matter</h1>
      <p class="text-(--color-fg-muted) leading-relaxed max-w-prose">
        A regular column on ThePrint surfacing the Indian liberal tradition for a contemporary readership. Mirrored here so AI agents can read every piece; the canonical version of each post lives on <a href="https://theprint.in/category/opinion/indian-liberals-matter/" class="text-(--color-forest-700)">ThePrint</a>.
      </p>
    </div>
  </section>
  <section>
    <div class="mx-auto max-w-3xl px-6 py-12">
      <p class="text-(--color-fg-muted) text-sm mb-8 font-(family-name:--font-ui)">
        {posts.length} pieces mirrored.
      </p>
      <ul class="divide-y divide-(--color-border)">
        {posts.map((p) => (
          <li class="py-6">
            <a href={`/theprint-mirror/${p.id}/`} class="block no-underline group">
              <p class="text-xs text-(--color-fg-muted) font-(family-name:--font-ui) mb-1">
                {new Date(p.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })} · {p.data.author_name}
              </p>
              <h2 class="font-(family-name:--font-display) text-(--color-fg) group-hover:text-(--color-saffron-700) transition-colors text-xl leading-snug">
                {p.data.title}
              </h2>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
