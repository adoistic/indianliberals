---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { hreflangAlternates, shouldNoindex } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";

export async function getStaticPaths() {
  const thinkers = await getCollection(
    "thinkers",
    (t) => !t.data.draft && t.data.language === "en",
  );
  return thinkers.map((t) => ({ params: { slug: t.id }, props: { t } }));
}

const { t } = Astro.props;
const { Content } = await render(t);

// Compute the three-role aggregations at build time. Each Tier-A entry
// has a structured ref pointing to one or more thinkers; we partition
// per the three-role model defined in the cross-link audit spec:
//
//   author  — this thinker WROTE the entry (musings, primary-works,
//             theprint-mirror, opinions with a thinker-author)
//   subject — the entry is ABOUT this thinker (opinions w/ `subject`,
//             interviews w/ `subject`)
//   mention — appears in related_thinkers but is neither author nor
//             subject. Phase B will populate these from in-prose NER.

const [allInterviews, allTheprint, allOpinions, allMusings, allWorks] = await Promise.all([
  getCollection("interviews", (e) => !e.data.draft),
  getCollection("theprint-mirror", (e) => !e.data.draft),
  getCollection("opinions", (e) => !e.data.draft),
  getCollection("musings", (e) => !e.data.draft),
  getCollection("primary-works", (e) => !e.data.draft && e.data.language === "en"),
]);

function refMatches(ref: { id?: string } | string | undefined, id: string): boolean {
  if (!ref) return false;
  if (typeof ref === "string") return ref === id;
  return ref.id === id;
}

// ─── Author role: works/pieces the thinker WROTE ─────────────────────
const worksByThisThinker = allWorks
  .filter((w) =>
    (w.data.authors ?? []).some((a) => refMatches(a, t.id)) ||
    (w.data.contributors ?? []).some((c) => refMatches(c.thinker, t.id)),
  )
  .sort((a, b) => (b.data.publication?.year ?? 0) - (a.data.publication?.year ?? 0));
const musingsByThisThinker = allMusings.filter((m) => refMatches(m.data.author, t.id));
const opinionsByThisThinker = allOpinions.filter((o) => refMatches(o.data.author, t.id));
const theprintByThisThinker = allTheprint.filter((p) =>
  (p.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
);

// ─── Subject role: pieces ABOUT the thinker ──────────────────────────
const interviewsAbout = allInterviews.filter((i) => refMatches(i.data.subject, t.id));
const opinionsAbout = allOpinions.filter((o) => refMatches(o.data.subject, t.id));

// ─── Mention role: appears in related_thinkers but not as author/subject ─
const opinionMentions = allOpinions.filter((o) =>
  !refMatches(o.data.author, t.id) &&
  !refMatches(o.data.subject, t.id) &&
  (o.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
);
const musingMentions = allMusings.filter((m) =>
  !refMatches(m.data.author, t.id) &&
  (m.data.related_thinkers ?? []).some((r) => refMatches(r, t.id))
);
// (theprint mentions are currently the byline; mention-only role for
// theprint requires Phase B body-NER and is intentionally empty here.)

const authorshipCount =
  worksByThisThinker.length + musingsByThisThinker.length +
  opinionsByThisThinker.length + theprintByThisThinker.length;
const aboutCount = interviewsAbout.length + opinionsAbout.length;
const mentionCount = opinionMentions.length + musingMentions.length;

const hreflang = hreflangAlternates(
  "thinkers",
  t.id,
  t.data.language,
  t.data.translations,
  Astro.site!.origin,
);

const treatment = t.data.portrait?.caricature
  ? { src: t.data.portrait.caricature, kind: "caricature" as const }
  : t.data.portrait?.ring_portrait
    ? { src: t.data.portrait.ring_portrait, kind: "ring" as const }
    : t.data.portrait?.photo
      ? { src: t.data.portrait.photo, kind: "photo" as const }
      : null;

const datesStr =
  t.data.birth_year && t.data.death_year
    ? `${t.data.birth_year}–${t.data.death_year}`
    : t.data.birth_year
      ? `b. ${t.data.birth_year}`
      : "";

const bioSourceLabel = {
  canonical: "Canonical bio",
  feature_article: "From feature article",
  ai_drafted: "Draft — under review",
  imported: "Imported from previous site",
}[t.data.bio_source];
---

<BaseLayout
  title={`${t.data.name.canonical} — Indian Liberals`}
  description={`Biographical profile of ${t.data.name.canonical}${datesStr ? ` (${datesStr})` : ""}.`}
  lang={t.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(t.data.translation_status)}
>
  <article
    class="mx-auto max-w-4xl px-6 py-12 md:py-16"
    data-pagefind-filter={`type:thinker,lang:${t.data.language}`}
    data-pagefind-meta={`tradition:${t.data.tradition}`}
  >
    <header class="border-b border-(--color-border) pb-10 mb-10 grid md:grid-cols-[auto_1fr] gap-8 items-start">
      {treatment && (
        <div class="w-40 md:w-48 aspect-[3/4] bg-(--color-bg-muted) rounded-sm overflow-hidden flex items-end justify-center">
          <img
            src={treatment.src}
            alt={`Portrait of ${t.data.name.canonical}`}
            width="288"
            height="384"
            class={treatment.kind === "ring" ? "w-full h-full object-cover" : "w-full h-full object-contain object-bottom"}
          />
        </div>
      )}
      <div>
        <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-2">
          {t.data.tradition.replace(/_/g, " ")}
        </p>
        <h1 class="text-(--color-fg) leading-tight">{t.data.name.canonical}</h1>
        {t.data.name.full && t.data.name.full !== t.data.name.canonical && (
          <p class="text-(--color-fg-muted) font-(family-name:--font-display) italic text-lg mt-1">
            {t.data.name.full}
          </p>
        )}
        {datesStr && (
          <p class="text-(--color-fg-muted) font-(family-name:--font-ui) mt-3 text-base">{datesStr}</p>
        )}
        {t.data.name.also_known_as.length > 0 && (
          <p class="text-(--color-fg-muted) text-sm mt-3 font-(family-name:--font-ui)">
            Also known as: {t.data.name.also_known_as.join(", ")}
          </p>
        )}
        <p class="text-xs uppercase tracking-widest text-(--color-fg-muted) font-(family-name:--font-ui) mt-6">
          {bioSourceLabel}
        </p>
      </div>
    </header>

    <div class="prose-container">
      <div class="text-(--color-fg) leading-relaxed [&_p]:my-5 [&_p]:text-[1.0625rem] [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_a]:text-(--color-forest-700) [&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-6 [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted)">
        <Content />
      </div>
    </div>

    {(t.data.themes.length > 0 || t.data.affiliations.length > 0) && (
      <aside class="mt-12 pt-8 border-t border-(--color-border) grid md:grid-cols-2 gap-8 font-(family-name:--font-ui) text-sm">
        {t.data.themes.length > 0 && (
          <div>
            <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-3">Themes</h2>
            <ul class="flex flex-wrap gap-2">
              {t.data.themes.map((th) => (
                <li class="px-2.5 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded-full text-(--color-fg)">{th.replace(/_/g, " ")}</li>
              ))}
            </ul>
          </div>
        )}
        {t.data.affiliations.length > 0 && (
          <div>
            <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-3">Affiliations</h2>
            <ul class="space-y-1">
              {t.data.affiliations.map((a) => (
                <li><a href={`/organisations/${a}/`} class="text-(--color-forest-700)">{a.replace(/-/g, " ")}</a></li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    )}

    {/* ── Section 1: Works BY this thinker ────────────────────────── */}
    {authorshipCount > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          By {t.data.name.canonical} ({authorshipCount})
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {worksByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Primary works ({worksByThisThinker.length})</h3>
              <ul class="space-y-2">
                {worksByThisThinker.slice(0, 15).map((w) => (
                  <li>
                    <a href={`/primary-works/${w.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {w.data.title.main}
                      <span class="text-(--color-fg-muted) ml-1">· {w.data.publication?.year ?? "n.d."}</span>
                    </a>
                  </li>
                ))}
                {worksByThisThinker.length > 15 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {worksByThisThinker.length - 15} more</li>
                )}
              </ul>
            </div>
          )}
          {musingsByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Excerpts ({musingsByThisThinker.length})</h3>
              <ul class="space-y-2">
                {musingsByThisThinker.slice(0, 10).map((m) => (
                  <li>
                    <a href={`/musings/${m.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {m.data.title}
                    </a>
                  </li>
                ))}
                {musingsByThisThinker.length > 10 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {musingsByThisThinker.length - 10} more</li>
                )}
              </ul>
            </div>
          )}
          {opinionsByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Opinion pieces ({opinionsByThisThinker.length})</h3>
              <ul class="space-y-2">
                {opinionsByThisThinker.map((o) => (
                  <li>
                    <a href={`/opinions/${o.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {o.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {theprintByThisThinker.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">In ThePrint ({theprintByThisThinker.length})</h3>
              <ul class="space-y-2">
                {theprintByThisThinker.slice(0, 10).map((p) => (
                  <li>
                    <a href={p.data.theprint_url} target="_blank" rel="noopener canonical" class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {p.data.title}
                      <span aria-hidden class="text-(--color-fg-muted) ml-1">↗</span>
                    </a>
                  </li>
                ))}
                {theprintByThisThinker.length > 10 && (
                  <li class="text-sm text-(--color-fg-muted)">…and {theprintByThisThinker.length - 10} more</li>
                )}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {/* ── Section 2: Profile pieces / interviews ABOUT this thinker ─── */}
    {aboutCount > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          About {t.data.name.canonical} ({aboutCount})
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {interviewsAbout.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Interviews ({interviewsAbout.length})</h3>
              <ul class="space-y-2">
                {interviewsAbout.map((i) => (
                  <li>
                    <a href={`/interviews/${i.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {i.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {opinionsAbout.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Profile pieces ({opinionsAbout.length})</h3>
              <ul class="space-y-2">
                {opinionsAbout.map((o) => (
                  <li>
                    <a href={`/opinions/${o.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {o.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </section>
    )}

    {/* ── Section 3: Mentioned in (Phase A: only structured related_thinkers; Phase B will populate from in-prose NER) ── */}
    {mentionCount > 0 && (
      <section class="mt-12 pt-8 border-t border-(--color-border) font-(family-name:--font-ui)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted) mb-4">
          Mentioned in ({mentionCount})
        </h2>
        <div class="grid gap-6 md:grid-cols-2">
          {opinionMentions.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Opinion pieces ({opinionMentions.length})</h3>
              <ul class="space-y-2">
                {opinionMentions.slice(0, 10).map((o) => (
                  <li>
                    <a href={`/opinions/${o.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {o.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {musingMentions.length > 0 && (
            <div>
              <h3 class="text-sm font-semibold text-(--color-fg) mb-2">Excerpts ({musingMentions.length})</h3>
              <ul class="space-y-2">
                {musingMentions.slice(0, 10).map((m) => (
                  <li>
                    <a href={`/musings/${m.id}/`} class="text-sm text-(--color-forest-700) no-underline hover:underline">
                      {m.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        <p class="mt-4 text-xs text-(--color-fg-muted) italic">
          In-prose mentions (names appearing inside article bodies and primary-work summaries) are queued for the Phase B linking pass.
        </p>
      </section>
    )}

    <RelatedSection collection="thinkers" slug={t.id} viewerLang={t.data.language} />
  </article>
</BaseLayout>
