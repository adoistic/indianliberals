---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE } from "~/lib/i18n";
import ThinkerDetail from "~/components/ThinkerDetail.astro";

export async function getStaticPaths() {
  const thinkers = await getCollection(
    "thinkers",
    (t) => !t.data.draft && t.data.language === DEFAULT_LOCALE,
  );
  return thinkers.map((t) => ({ params: { slug: t.id }, props: { t } }));
}

const { t } = Astro.props;
---

<ThinkerDetail entry={t} />
