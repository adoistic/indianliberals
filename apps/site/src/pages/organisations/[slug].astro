---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE } from "~/lib/i18n";
import OrganisationDetail from "~/components/OrganisationDetail.astro";

export async function getStaticPaths() {
  const orgs = await getCollection(
    "organisations",
    (o) => !o.data.draft && o.data.language === DEFAULT_LOCALE,
  );
  return orgs.map((o) => ({ params: { slug: o.id }, props: { o } }));
}

const { o } = Astro.props;
---

<OrganisationDetail entry={o} />
