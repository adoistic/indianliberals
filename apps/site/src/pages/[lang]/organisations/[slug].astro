---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE, LOCALES, type LangCode } from "~/lib/i18n";
import OrganisationDetail from "~/components/OrganisationDetail.astro";

export async function getStaticPaths() {
  const orgs = await getCollection(
    "organisations",
    (o) => !o.data.draft && o.data.language !== DEFAULT_LOCALE,
  );
  return orgs
    .filter((o) => LOCALES.includes(o.data.language as LangCode))
    .map((o) => ({
      params: { lang: o.data.language, slug: o.id },
      props: { o },
    }));
}

const { o } = Astro.props;
---

<OrganisationDetail entry={o} />
