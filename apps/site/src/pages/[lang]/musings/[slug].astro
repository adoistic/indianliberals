---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE, LOCALES, type LangCode } from "~/lib/i18n";
import MusingDetail from "~/components/MusingDetail.astro";

export async function getStaticPaths() {
  const musings = await getCollection(
    "musings",
    (m) => !m.data.draft && m.data.language !== DEFAULT_LOCALE,
  );
  return musings
    .filter((m) => LOCALES.includes(m.data.language as LangCode))
    .map((m) => ({
      params: { lang: m.data.language, slug: m.id },
      props: { m },
    }));
}

const { m } = Astro.props;
---

<MusingDetail entry={m} />
