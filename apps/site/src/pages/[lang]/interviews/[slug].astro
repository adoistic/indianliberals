---
import { getCollection } from "astro:content";
import { LOCALES, DEFAULT_LOCALE, type LangCode } from "~/lib/i18n";
import InterviewDetail from "~/components/InterviewDetail.astro";

export async function getStaticPaths() {
  const interviews = await getCollection(
    "interviews",
    (i) => !i.data.draft && i.data.language !== DEFAULT_LOCALE,
  );
  return interviews
    .filter((i) => LOCALES.includes(i.data.language as LangCode))
    .map((i) => ({
      params: { lang: i.data.language, slug: i.id },
      props: { i },
    }));
}

const { i } = Astro.props;
---

<InterviewDetail entry={i} />
