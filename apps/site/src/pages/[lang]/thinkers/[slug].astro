---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE, LOCALES, type LangCode } from "~/lib/i18n";
import ThinkerDetail from "~/components/ThinkerDetail.astro";

export async function getStaticPaths() {
  const thinkers = await getCollection(
    "thinkers",
    (t) => !t.data.draft && t.data.language !== DEFAULT_LOCALE,
  );
  return thinkers
    .filter((t) => LOCALES.includes(t.data.language as LangCode))
    .map((t) => ({
      params: { lang: t.data.language, slug: t.id },
      props: { t },
    }));
}

const { t } = Astro.props;
---

<ThinkerDetail entry={t} />
