---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import {
  hreflangAlternates,
  shouldNoindex,
  LOCALES,
  DEFAULT_LOCALE,
  type LangCode,
} from "~/lib/i18n";

export async function getStaticPaths() {
  const opinions = await getCollection(
    "opinions",
    (o) => !o.data.draft && o.data.language !== DEFAULT_LOCALE,
  );
  return opinions
    .filter((o) => LOCALES.includes(o.data.language as LangCode))
    .map((o) => ({
      params: { lang: o.data.language, slug: o.id },
      props: { o },
    }));
}

const { o } = Astro.props;
const { Content } = await render(o);

const hreflang = hreflangAlternates(
  "opinions",
  o.id,
  o.data.language,
  o.data.translations,
  Astro.site!.origin,
);
---

<BaseLayout
  title={`${o.data.title} — Indian Liberals`}
  lang={o.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(o.data.translation_status)}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16">
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        Opinion
      </p>
      <h1 class="text-(--color-fg) leading-tight" lang={o.data.language}>{o.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(o.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}
        {o.data.author_name && o.data.author_name !== "CCS Editorial Team" && (<><span> · {o.data.author_name}</span></>)}
      </p>
    </header>
    <div class="prose-container text-(--color-fg) leading-relaxed text-[1.0625rem] [&_p]:my-5 [&_h2]:mt-10 [&_h2]:mb-4 [&_h3]:mt-8 [&_h3]:mb-3 [&_a]:text-(--color-forest-700) [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted) [&_blockquote]:my-5" lang={o.data.language}>
      <Content />
    </div>
  </article>
</BaseLayout>
