---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE, LOCALES, type LangCode } from "~/lib/i18n";
import OpinionDetail from "~/components/OpinionDetail.astro";

export async function getStaticPaths() {
  const opinions = await getCollection(
    "opinions",
    (o) => !o.data.draft && o.data.language !== DEFAULT_LOCALE,
  );
  return opinions
    .filter((o) => LOCALES.includes(o.data.language as LangCode))
    .map((o) => ({
      params: { lang: o.data.language, slug: o.id },
      props: { o },
    }));
}

const { o } = Astro.props;
---

<OpinionDetail entry={o} />
