---
// Primary-works index — chronological list with faceted client-side filters.
//
// Filters (Type / Decade / Theme) are pure client-side JS toggling `<li>`
// visibility via data-* attributes. No server, no API; works on the static
// build. Reset button clears all selections.

import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { LANG_NAMES, pathForEntry, type LangCode } from "~/lib/i18n";

const allWorks = await getCollection(
  "primary-works",
  (w) => !w.data.draft,
);

// Sort by publication year desc, then title for stable ordering within a year.
const works = allWorks.slice().sort((a, b) => {
  const ya = a.data.publication?.year ?? -Infinity;
  const yb = b.data.publication?.year ?? -Infinity;
  if (ya !== yb) return yb - ya;
  return a.data.title.main.localeCompare(b.data.title.main);
});

// Group by decade for visual scanning.
type Decade = { label: string; start: number; works: typeof works };
const decades: Decade[] = [];
let current: Decade | null = null;
for (const w of works) {
  const y = w.data.publication?.year;
  const decadeStart = y != null ? Math.floor(y / 10) * 10 : null;
  const label = decadeStart == null ? "Undated" : `${decadeStart}s`;
  if (!current || current.label !== label) {
    current = { label, start: decadeStart ?? -Infinity, works: [] };
    decades.push(current);
  }
  current.works.push(w);
}

const totalCount = works.length;

// Build facet vocabularies for the filter UI.
const typeCounts = new Map<string, number>();
const themeCounts = new Map<string, number>();
const languageCounts = new Map<string, number>();
for (const w of works) {
  const t = w.data.work_type;
  typeCounts.set(t, (typeCounts.get(t) ?? 0) + 1);
  const lang = w.data.language ?? "en";
  languageCounts.set(lang, (languageCounts.get(lang) ?? 0) + 1);
  for (const th of w.data.themes ?? []) {
    themeCounts.set(th, (themeCounts.get(th) ?? 0) + 1);
  }
}

// Order: type alphabetical; themes by count desc (most-used first)
const typeOptions = [...typeCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const themeOptions = [...themeCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 30); // top 30 themes
const decadeOptions = decades.map((d) => ({ label: d.label, start: d.start, count: d.works.length }));
// Language: English first (most common), then by count desc.
const languageOptions = [...languageCounts.entries()].sort((a, b) => {
  if (a[0] === "en") return -1;
  if (b[0] === "en") return 1;
  return b[1] - a[1];
});

// Helper for the data attribute that holds space-joined themes.
function themesAttr(w: (typeof works)[number]): string {
  return (w.data.themes ?? []).join(" ");
}
---

<BaseLayout
  title="Primary works — Indian Liberals"
  description={`${totalCount} primary works by Indian liberal thinkers, from speeches and pamphlets to books and essays. Metadata + AI summary + PDF.`}
>
  <section class="border-b border-(--color-border)">
    <div class="mx-auto max-w-5xl px-6 py-16">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        The archive
      </p>
      <h1 class="text-(--color-fg) leading-tight">Primary works</h1>
      <p class="mt-4 text-(--color-fg-muted) max-w-prose leading-relaxed">
        {totalCount} books, pamphlets, essays, and speeches by historically
        significant Indian liberal thinkers. Each entry surfaces with rich
        AI-extracted metadata, a prose summary, key points, and a link to the
        source PDF. Paragraph-level citation inside the PDF is deferred to a
        future engagement.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-12 md:grid md:grid-cols-[220px_1fr] md:gap-10" data-pagefind-ignore>
    {/* Filter sidebar — sticky left rail on md+, stacks on top on mobile */}
    <aside
      class="
        font-(family-name:--font-ui) text-sm mb-8 md:mb-0
        md:sticky md:top-[5.5rem] md:self-start
        md:max-h-[calc(100vh-6rem)] md:overflow-y-auto md:pr-2
      "
      aria-label="Filter primary works"
    >
      <div class="flex items-baseline justify-between gap-3 mb-3 pb-3 border-b border-(--color-border)">
        <h2 class="text-xs uppercase tracking-widest text-(--color-fg-muted)">Filter</h2>
        <button id="pw-reset" type="button" class="text-[10px] uppercase tracking-wider text-(--color-saffron-700) font-semibold hover:text-(--color-fg) hidden">
          Reset
        </button>
      </div>
      <p class="text-xs text-(--color-fg-muted) mb-5">
        Showing <strong id="pw-counter-visible" class="text-(--color-fg)">{totalCount}</strong> of <strong>{totalCount}</strong>
      </p>

      <div class="mb-5">
        <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Type</h3>
        <ul class="flex flex-wrap gap-1.5">
          {typeOptions.map(([t, n]) => (
            <li>
              <button
                type="button"
                data-filter-type={t}
                class="pw-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
              >
                {t.replace(/_/g, " ")} <span class="opacity-70">({n})</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      {languageOptions.length > 1 && (
        <div class="mb-5">
          <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Language</h3>
          <ul class="flex flex-wrap gap-1.5">
            {languageOptions.map(([lang, n]) => {
              const names = LANG_NAMES[lang as LangCode];
              const label = names ? names.english : lang;
              return (
                <li>
                  <button
                    type="button"
                    data-filter-language={lang}
                    class="pw-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
                  >
                    {label} <span class="opacity-70">({n})</span>
                  </button>
                </li>
              );
            })}
          </ul>
        </div>
      )}

      <div class="mb-5">
        <h3 class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) mb-2">Decade</h3>
        <ul class="flex flex-wrap gap-1.5">
          {decadeOptions.map((d) => (
            <li>
              <button
                type="button"
                data-filter-decade={String(d.start)}
                class="pw-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
              >
                {d.label} <span class="opacity-70">({d.count})</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <details class="mb-5" open>
        <summary class="text-[10px] uppercase tracking-wider text-(--color-fg-muted) cursor-pointer select-none hover:text-(--color-fg) mb-2">Themes ▾</summary>
        <ul class="flex flex-wrap gap-1.5">
          {themeOptions.map(([th, n]) => (
            <li>
              <button
                type="button"
                data-filter-theme={th}
                class="pw-chip px-2 py-1 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs text-(--color-fg) hover:border-(--color-fg) transition-colors"
              >
                {th.replace(/_/g, " ").replace(/-/g, " ")} <span class="opacity-70">({n})</span>
              </button>
            </li>
          ))}
        </ul>
      </details>
    </aside>

    {/* Listing column */}
    <div id="pw-list" class="min-w-0">
    {decades.map((d) => (
      <section class="mb-12 pw-section" data-decade={String(d.start)}>
        <h2 class="text-(--color-fg) font-(family-name:--font-display) mb-6 sticky top-[4.75rem] bg-(--color-bg) py-2 z-10 border-b border-(--color-border)">
          {d.label}
        </h2>
        <ul class="divide-y divide-(--color-border)">
          {d.works.map((w) => {
            const y = w.data.publication?.year;
            const pubName = w.data.publication?.publisher_name;
            const subtitle = w.data.title.subtitle;
            const byline = (w.data.contributors ?? [])
              .filter((c) => c.role === "author")
              .map((c) => c.thinker_unresolved || (c.thinker as { id?: string } | undefined)?.id || "")
              .filter(Boolean)
              .join(", ");
            return (
              <li
                class="pw-item py-5"
                data-type={w.data.work_type}
                data-decade={String(d.start)}
                data-themes={themesAttr(w)}
                data-language={w.data.language ?? "en"}
              >
                <a href={pathForEntry("primary-works", w.id, (w.data.language ?? "en") as LangCode)} class="block group no-underline">
                  <h3 class="font-(family-name:--font-display) font-semibold text-(--color-fg) group-hover:text-(--color-saffron-700) transition-colors leading-snug">
                    {w.data.title.main}
                    {subtitle && <span class="text-(--color-fg-muted) font-normal italic">: {subtitle}</span>}
                  </h3>
                  <p class="mt-1 text-sm text-(--color-fg-muted) font-(family-name:--font-ui)">
                    {byline && <>{byline} · </>}
                    {y && <>{y}</>}
                    {pubName && <> · {pubName.split(/[\.,]/)[0]}</>}
                    <span class="ml-2 px-2 py-0.5 bg-(--color-bg-muted) border border-(--color-border) rounded text-xs uppercase tracking-wider">
                      {w.data.work_type.replace(/_/g, " ")}
                    </span>
                  </p>
                </a>
              </li>
            );
          })}
        </ul>
      </section>
    ))}
    <p id="pw-empty" class="hidden text-center py-12 text-(--color-fg-muted) font-(family-name:--font-ui)">
      No works match the current filter. Try removing some criteria.
    </p>
    </div>
  </div>

  <script is:inline>
    // Client-side faceted filtering for /primary-works/.
    // State lives in Sets; toggling a chip flips active class + filters items.
    (function () {
      const state = { type: new Set(), decade: new Set(), theme: new Set(), language: new Set() };
      const items = Array.from(document.querySelectorAll('.pw-item'));
      const sections = Array.from(document.querySelectorAll('.pw-section'));
      const totalEl = document.getElementById('pw-counter-visible');
      const resetBtn = document.getElementById('pw-reset');
      const emptyEl = document.getElementById('pw-empty');
      const ACTIVE = ['bg-(--color-saffron-500)', 'text-white', 'border-(--color-saffron-500)'];
      const IDLE = ['bg-(--color-bg)', 'text-(--color-fg)', 'border-(--color-border)'];

      function applyFilters() {
        let visible = 0;
        for (const li of items) {
          const t = li.dataset.type;
          const d = li.dataset.decade;
          const lang = li.dataset.language;
          const themes = (li.dataset.themes || '').split(/\s+/).filter(Boolean);
          const matchType     = state.type.size === 0 || state.type.has(t);
          const matchDecade   = state.decade.size === 0 || state.decade.has(d);
          const matchTheme    = state.theme.size === 0 || themes.some((x) => state.theme.has(x));
          const matchLanguage = state.language.size === 0 || state.language.has(lang);
          const show = matchType && matchDecade && matchTheme && matchLanguage;
          li.style.display = show ? '' : 'none';
          if (show) visible++;
        }
        // Hide whole section if all its <li> are hidden
        for (const sec of sections) {
          const anyVisible = Array.from(sec.querySelectorAll('.pw-item')).some(
            (li) => li.style.display !== 'none'
          );
          sec.style.display = anyVisible ? '' : 'none';
        }
        if (totalEl) totalEl.textContent = String(visible);
        if (emptyEl) emptyEl.classList.toggle('hidden', visible !== 0);
        if (resetBtn) {
          const anyActive = state.type.size + state.decade.size + state.theme.size + state.language.size > 0;
          resetBtn.classList.toggle('hidden', !anyActive);
        }
      }

      function toggleChip(btn, facet, value) {
        const set = state[facet];
        if (set.has(value)) {
          set.delete(value);
          IDLE.forEach((c) => btn.classList.add(c));
          ACTIVE.forEach((c) => btn.classList.remove(c));
        } else {
          set.add(value);
          ACTIVE.forEach((c) => btn.classList.add(c));
          IDLE.forEach((c) => btn.classList.remove(c));
        }
        applyFilters();
      }

      document.querySelectorAll('.pw-chip').forEach((btn) => {
        btn.addEventListener('click', () => {
          if (btn.dataset.filterType) toggleChip(btn, 'type', btn.dataset.filterType);
          else if (btn.dataset.filterDecade) toggleChip(btn, 'decade', btn.dataset.filterDecade);
          else if (btn.dataset.filterTheme) toggleChip(btn, 'theme', btn.dataset.filterTheme);
          else if (btn.dataset.filterLanguage) toggleChip(btn, 'language', btn.dataset.filterLanguage);
        });
      });

      if (resetBtn) {
        resetBtn.addEventListener('click', () => {
          state.type.clear();
          state.decade.clear();
          state.theme.clear();
          state.language.clear();
          document.querySelectorAll('.pw-chip').forEach((btn) => {
            ACTIVE.forEach((c) => btn.classList.remove(c));
            IDLE.forEach((c) => btn.classList.add(c));
          });
          applyFilters();
        });
      }
    })();
  </script>
</BaseLayout>
