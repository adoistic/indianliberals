---
import { getCollection } from "astro:content";
import { DEFAULT_LOCALE } from "~/lib/i18n";
import MusingDetail from "~/components/MusingDetail.astro";

export async function getStaticPaths() {
  const musings = await getCollection(
    "musings",
    (m) => !m.data.draft && m.data.language === DEFAULT_LOCALE,
  );
  return musings.map((m) => ({ params: { slug: m.id }, props: { m } }));
}

const { m } = Astro.props;
---

<MusingDetail entry={m} />
