---
import BaseLayout from "~/layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { hreflangAlternates, shouldNoindex } from "~/lib/i18n";
import RelatedSection from "~/components/RelatedSection.astro";

export async function getStaticPaths() {
  const musings = await getCollection(
    "musings",
    (m) => !m.data.draft && m.data.language === "en",
  );
  return musings.map((m) => ({ params: { slug: m.id }, props: { m } }));
}

const { m } = Astro.props;
const { Content } = await render(m);

const hreflang = hreflangAlternates(
  "musings",
  m.id,
  m.data.language,
  m.data.translations,
  Astro.site!.origin,
);
---

<BaseLayout
  title={`${m.data.title} — Indian Liberals`}
  lang={m.data.language}
  hreflang={hreflang}
  noindex={shouldNoindex(m.data.translation_status)}
>
  <article class="mx-auto max-w-3xl px-6 py-12 md:py-16" data-pagefind-filter={`type:musing,lang:${m.data.language}`}>
    <header class="border-b border-(--color-border) pb-8 mb-10">
      <p class="text-xs uppercase tracking-widest text-(--color-saffron-700) font-(family-name:--font-ui) font-semibold mb-3">
        Musing · excerpt
      </p>
      <h1 class="text-(--color-fg) leading-tight">{m.data.title}</h1>
      <p class="mt-4 text-(--color-fg-muted) font-(family-name:--font-ui) text-sm">
        {new Date(m.data.pubDate).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}
      </p>
    </header>
    <div class="prose-container text-(--color-fg) leading-relaxed text-[1.0625rem] [&_p]:my-5 [&_a]:text-(--color-forest-700) [&_blockquote]:border-l-2 [&_blockquote]:border-(--color-saffron-500) [&_blockquote]:pl-4 [&_blockquote]:italic [&_blockquote]:text-(--color-fg-muted) [&_blockquote]:my-5">
      <Content />
    </div>

    <RelatedSection collection="musings" slug={m.id} viewerLang={m.data.language} />
  </article>
</BaseLayout>
