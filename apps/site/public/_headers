# Cloudflare Pages cache headers.
# Astro emits content-hashed asset paths under /_astro/, so they can be
# cached aggressively. Everything else gets shorter TTLs so editorial
# updates land within minutes.

# Content-hashed assets — immutable, cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Pagefind search bundle — content-hashed under pagefind/
/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# Brand assets (logos, type, portraits)
/brand/*
  Cache-Control: public, max-age=2592000

/thinkers/*
  Cache-Control: public, max-age=2592000

/legacy-media/*
  Cache-Control: public, max-age=2592000

# AGENTS.md and llms.txt — refreshed on rebuild, no aggressive caching
/AGENTS.md
  Cache-Control: public, max-age=3600
  Content-Type: text/markdown; charset=utf-8

/llms.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

/llms-full.txt
  Cache-Control: public, max-age=3600
  Content-Type: text/plain; charset=utf-8

# .md siblings (one per Tier-A detail page) — same TTL as the HTML page
/*.md
  Cache-Control: public, max-age=600
  Content-Type: text/markdown; charset=utf-8

# Default for all HTML pages — short TTL so editorial updates land fast
# Cloudflare's CDN purges on every Pages deploy automatically, so this
# is the BROWSER-side cache only.
/*
  Cache-Control: public, max-age=300, s-maxage=3600
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
